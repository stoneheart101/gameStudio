            PackContents: ["Trail Rations (5 days)", "Basic Tool Kit", "Flint & Steel", "Waterskin (full)", "Hemp Rope (50ft)", "3 Torches", "20 Silver Coins"]);
        invItems[1]  = new InvItem(IconBroadsword, "Iron Sword",         "A straight iron blade. Well-balanced.",         "Strike with Sword");
