@page "/forward"
@rendermode InteractiveServer
@inject UserSession UserSession
@implements IDisposable

<PageTitle>Forward - Game Studio</PageTitle>

<div class="forward-page">

    <header class="fw-header">
        <span class="fw-title">FORWARD</span>
        <div class="fw-header-right">
            <a href="/" class="fw-back-link">&#8592; Back to Games</a>
            @if (UserSession.CurrentUser != null)
            {
                <span class="fw-playing-as">Playing as @UserSession.CurrentUser.Name</span>
            }
        </div>
    </header>

    @if (!initialized)
    {
        <div class="fw-loading-msg">LOADING...</div>
    }
    else if (UserSession.CurrentUser == null)
    {
        <div class="fw-loading-msg">
            <p>CREATE A PLAYER PROFILE FIRST</p>
            <a href="/" class="fw-btn">GO HOME</a>
        </div>
    }
    else
    {
        <div class="fw-main">

            <!-- ── TOP SECTION: Map | Character | Inventory ───────────── -->
            <div class="fw-top">

                <!-- Map panel — left 40% -->
                <div class="fw-panel fw-map-panel">
                    <div class="fw-panel-label">MAP</div>
                    <div class="fw-map-area @(mapIsSliding ? "is-sliding" : "")">
                        @for (var ri = 0; ri < mapRows.Length; ri++)
                        {
                            var row    = mapRows[ri];
                            var rowNum = ri + 1;
                            for (var ci = 0; ci < 5; ci++)
                            {
                                if (row.Slots[ci].HasValue)
                                {
                                    var r        = ri;
                                    var c        = ci;
                                    if (!IsVisible(r, c)) continue;
                                    var colStart     = row.IsOffset ? (c * 2 + 2) : (c * 2 + 1);
                                    var isPlayer     = r == playerPos.Row && c == playerPos.Col;
                                    var canMove      = !isPlayer && IsValidMove(r, c);
                                    var isVisited    = visitedSlots.Contains((r, c));
                                    var stateCls     = isPlayer ? "is-player" : canMove ? "is-reachable" : "";
                                    var visitedCls   = isVisited ? "is-visited" : "";
                                    var info         = GetAreaInfo(row.Slots[c]!.Value);
                                    var goalId       = row.QuestGoals[c];
                                    var hasQuestGoal = goalId != null && activeQuests.Any(q => q.Id == goalId);
                                    <div class="fw-map-rect @stateCls @visitedCls at-@info.CssClass @(hasQuestGoal ? "has-quest-goal" : "")"
                                         style="grid-column:@(colStart) / span 2; grid-row:@rowNum;"
                                         @onclick="() => OnMapRectClick(r, c)">
                                        <span class="fw-map-icon" style="color:@info.IconColor;">
                                            @((MarkupString)info.Icon)
                                        </span>
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>

                <!-- Character panel — center 20% -->
                <div class="fw-panel fw-char-panel">
                    <div class="fw-char-name">@charName</div>
                    <div class="fw-skills-list">
                        @foreach (var sk in skills)
                        {
                            <div class="fw-skill-row" title="@(sk.RequiredItem != null ? "Requires: " + sk.RequiredItem : "No item required")">
                                <span class="fw-skill-name">@sk.Name</span>
                                <span class="fw-skill-uses">@sk.Uses</span>
                                @if (sk.Momentum > 0)
                                {
                                    <span class="fw-skill-momentum">+@sk.Momentum</span>
                                }
                            </div>
                        }
                    </div>
                    @if (activeQuests.Count > 0)
                    {
                        <div class="fw-quest-log">
                            <div class="fw-quest-log-label">QUESTS</div>
                            @foreach (var q in activeQuests)
                            {
                                <div class="fw-quest-entry" title="@q.Objective">
                                    <span class="fw-quest-type">[@q.Type.ToString()[..3].ToUpper()]</span>
                                    <span class="fw-quest-title">@q.Title</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Inventory panel — right 40% -->
                <div class="fw-panel fw-inv-panel">
                    <div class="fw-panel-label">INVENTORY</div>
                    <div class="fw-inv-grid">
                        @for (var i = 0; i < 12; i++)
                        {
                            var item      = i < invItems.Length ? invItems[i] : null;
                            var halfClass = (i % 4) < 2 ? "left-half" : "right-half";
                            <div class="fw-inv-slot @(item != null ? "has-item" : "") @halfClass">
                                @if (item != null)
                                {
                                    <span class="fw-inv-icon">@((MarkupString)item.Icon)</span>
                                    <div class="fw-inv-tip">
                                        <div class="fw-inv-tip-name">@item.Name</div>
                                        @if (item.PackContents != null)
                                        {
                                            <div class="fw-inv-tip-pack-label">CONTENTS:</div>
                                            @foreach (var pc in item.PackContents)
                                            {
                                                <div class="fw-inv-tip-pack-item">&#183; @pc</div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="fw-inv-tip-desc">@item.Desc</div>
                                            <div class="fw-inv-tip-uses">Uses: @item.Uses</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

            </div><!-- /fw-top -->

            <!-- ── BOTTOM SECTION: Area interaction ───────────────────── -->
            <div class="fw-bottom">
                <div class="fw-terrain-bg fw-terrain-@GetTerrainClass()"></div>

                <div class="fw-breadcrumb">
                    @for (var i = 0; i < areaPath.Count; i++)
                    {
                        var idx = i;
                        if (i > 0) { <span class="fw-crumb-sep">&#8250;</span> }
                        if (i < areaPath.Count - 1)
                        {
                            <span class="fw-crumb-link" @onclick="() => NavigateToCrumb(idx)">@areaPath[i]</span>
                        }
                        else
                        {
                            <span class="fw-crumb-current">@areaPath[i]</span>
                        }
                    }
                </div>

                <div class="fw-area-body">
                    @{
                        var curInfo = GetCurrentAreaInfo();
                    }
                    @{
                        var playerGoalId = mapRows[playerPos.Row].QuestGoals[playerPos.Col];
                        var playerQuest  = playerGoalId != null ? activeQuests.FirstOrDefault(q => q.Id == playerGoalId) : null;
                    }
                    @if (areaPath.Count == 1 && curInfo != null)
                    {
                        <div class="fw-area-info">
                            <div class="fw-area-icon" style="color:@curInfo.IconColor;">
                                @((MarkupString)curInfo.Icon)
                            </div>
                            <div class="fw-area-text">
                                <div class="fw-area-name">@curInfo.Name.ToUpper()</div>
                                <div class="fw-area-desc">@curInfo.Description</div>
                                @if (playerQuest != null)
                                {
                                    <div class="fw-quest-complete">
                                        &#10003; @playerQuest.CompletionText
                                        <button class="fw-btn fw-btn-leave" @onclick="CompleteCurrentQuestGoal">COMPLETE QUEST (+@playerQuest.XpReward XP)</button>
                                    </div>
                                }
                                @if (questMessage != null)
                                {
                                    <div class="fw-quest-complete">@questMessage</div>
                                }
                                @if (currentSubAreas.Count > 0)
                                {
                                    <div class="fw-subareas">
                                        @foreach (var sub in currentSubAreas)
                                        {
                                            var s = sub;
                                            <button class="fw-subarea-item" @onclick="() => EnterSubArea(s)">
                                                <span class="fw-subarea-icon" style="color:@s.IconColor;">@((MarkupString)s.Icon)</span>
                                                <span class="fw-subarea-name">@s.Name</span>
                                                <span class="fw-subarea-action">@s.ActionLabel</span>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else if (areaPath.Count > 1 && activeSubArea != null)
                    {
                        <div class="fw-area-info">
                            <div class="fw-area-icon" style="color:@activeSubArea.IconColor;">
                                @((MarkupString)activeSubArea.Icon)
                            </div>
                            <div class="fw-area-text">
                                <div class="fw-area-name">@activeSubArea.Name.ToUpper()</div>
                                <div class="fw-area-desc">@activeSubArea.Description</div>
                                @if (pendingQuestOffer != null)
                                {
                                    <div class="fw-quest-offer">
                                        <div class="fw-quest-offer-title">QUEST OFFER: @pendingQuestOffer.Title.ToUpper()</div>
                                        <div class="fw-quest-offer-text">@pendingQuestOffer.Objective</div>
                                        <div class="fw-quest-offer-btns">
                                            <button class="fw-btn" @onclick="AcceptQuest">ACCEPT</button>
                                            <button class="fw-btn" @onclick="DeclineQuest">DECLINE</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <p class="fw-stub-text">[ deeper exploration &mdash; coming soon ]</p>
                                }
                                <button class="fw-btn fw-btn-leave" @onclick="() => NavigateToCrumb(0)">&#8592; LEAVE</button>
                            </div>
                        </div>
                    }
                </div>
            </div><!-- /fw-bottom -->

        </div><!-- /fw-main -->

        <!-- ── STATUS BAR ─────────────────────────────────────────────── -->
        <div class="fw-status-bar">
            <div class="fw-sb-xp-wrap">
                <span class="fw-sb-label">XP</span>
                <div class="fw-sb-track">
                    <div class="fw-sb-fill" style="width:@XpPct%;"></div>
                </div>
                <span class="fw-sb-nums">@xpCurrent&thinsp;/&thinsp;@xpNext</span>
            </div>
            <div class="fw-sb-level">LVL&nbsp;@charLevel</div>
            <div class="fw-sb-statuses">
                @foreach (var s in statuses)
                {
                    <span class="fw-sb-status" title="@s.Label">@s.Icon</span>
                }
            </div>
        </div>

    }<!-- /else (logged in) -->

</div><!-- /forward-page -->

