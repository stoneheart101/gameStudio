@page "/forward"
@rendermode InteractiveServer
@inject UserSession UserSession
@implements IDisposable

<PageTitle>Forward - Game Studio</PageTitle>

<div class="forward-page">

    <header class="fw-header">
        <span class="fw-title">FORWARD</span>
        <div class="fw-header-right">
            <a href="/" class="fw-back-link">&#8592; Back to Games</a>
            @if (UserSession.CurrentUser != null)
            {
                <span class="fw-playing-as">Playing as @UserSession.CurrentUser.Name</span>
            }
        </div>
    </header>

    @if (!initialized)
    {
        <div class="fw-loading-msg">LOADING...</div>
    }
    else if (UserSession.CurrentUser == null)
    {
        <div class="fw-loading-msg">
            <p>CREATE A PLAYER PROFILE FIRST</p>
            <a href="/" class="fw-btn">GO HOME</a>
        </div>
    }
    else
    {
        <div class="fw-main">

            <!-- ── TOP SECTION: Map | Character | Inventory ───────────── -->
            <div class="fw-top">

                <!-- Map panel — left 40% -->
                <div class="fw-panel fw-map-panel">
                    <div class="fw-panel-label">MAP</div>
                    <div class="fw-map-area">
                        @for (var ri = 0; ri < mapRows.Length; ri++)
                        {
                            var row    = mapRows[ri];
                            var rowNum = ri + 1;
                            for (var ci = 0; ci < 5; ci++)
                            {
                                if (row.Slots[ci].HasValue)
                                {
                                    var r        = ri;
                                    var c        = ci;
                                    if (!IsVisible(r, c)) continue;
                                    var colStart     = row.IsOffset ? (c * 2 + 2) : (c * 2 + 1);
                                    var isPlayer     = r == playerPos.Row && c == playerPos.Col;
                                    var canMove      = !isPlayer && IsValidMove(r, c);
                                    var isVisited    = visitedSlots.Contains((r, c));
                                    var isNewVis     = newlyVisibleSlots.Contains((r, c));
                                    var isSlideDown  = slidingDownSlots.Contains((r, c));
                                    var hasDowntime  = downtimeSlots.ContainsKey((r, c));
                                    var stateCls     = isPlayer ? "is-player" : canMove ? "is-reachable" : "";
                                    var visitedCls   = isVisited ? "is-visited" : "";
                                    var info         = GetAreaInfo(row.Slots[c]!.Value);
                                    var goalId       = row.QuestGoals[c];
                                    var hasQuestGoal = goalId != null && activeQuests.Any(q => q.Id == goalId);
                                    <div class="fw-map-rect @stateCls @visitedCls at-@info.CssClass @(hasQuestGoal ? "has-quest-goal" : "") @(isNewVis ? "is-new-visible" : "") @(isSlideDown ? "is-slide-down" : "") @(hasDowntime ? "has-downtime" : "")"
                                         style="grid-column:@(colStart) / span 2; grid-row:@rowNum;"
                                         @onclick="() => OnMapRectClick(r, c)">
                                        <span class="fw-map-icon" style="color:@info.IconColor;">
                                            @((MarkupString)info.Icon)
                                        </span>
                                    </div>
                                }
                            }
                        }
                        <!-- Departing row (old bottom row animating out) -->
                        @if (departingRow != null)
                        {
                            for (var ci = 0; ci < 5; ci++)
                            {
                                if (departingRow.Slots[ci].HasValue && departingVisibleCols.Contains(ci))
                                {
                                    var c        = ci;
                                    var colStart = departingRow.IsOffset ? (c * 2 + 2) : (c * 2 + 1);
                                    var info     = GetAreaInfo(departingRow.Slots[c]!.Value);
                                    <div class="fw-map-rect is-departing is-visited at-@info.CssClass"
                                         style="grid-column:@(colStart) / span 2; grid-row:3; pointer-events:none;">
                                        <span class="fw-map-icon" style="color:@info.IconColor;">
                                            @((MarkupString)info.Icon)
                                        </span>
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>

                <!-- Character panel — center 20% -->
                <div class="fw-panel fw-char-panel">
                    <div class="fw-char-name">@charName</div>

                    <!-- Health -->
                    <div class="fw-health-block">
                        <div class="fw-health-row">
                            @for (var wi = 0; wi < 3; wi++)
                            {
                                <span class="fw-pip fw-pip-wound @(wi < wounds ? "is-filled" : "")">&#11043;</span>
                            }
                            <span class="fw-health-lbl">WOUNDS</span>
                        </div>
                        <div class="fw-health-row">
                            @for (var si = 0; si < 3; si++)
                            {
                                <span class="fw-pip fw-pip-scratch @(si < scratches ? "is-filled" : "")">&#183;</span>
                            }
                            <span class="fw-health-lbl">SCRATCHES</span>
                        </div>
                    </div>

                    <!-- Skills list (names only; active buttons appear in area body) -->
                    <div class="fw-skills-list">
                        @foreach (var sk in skills)
                        {
                            <div class="fw-skill-row" title="@(sk.RequiredItem != null ? "Requires: " + sk.RequiredItem : "No item required")">
                                <span class="fw-skill-name">@sk.Name</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Inventory panel — right 40% -->
                <div class="fw-panel fw-inv-panel">
                    <div class="fw-panel-label">INVENTORY</div>
                    <div class="fw-inv-grid">
                        @for (var i = 0; i < 12; i++)
                        {
                            var item      = i < invItems.Length ? invItems[i] : null;
                            var halfClass = (i % 4) < 2 ? "left-half" : "right-half";
                            var slotWear  = itemWear.GetValueOrDefault(i, 0f);
                            <div class="fw-inv-slot @(item != null ? "has-item" : "") @halfClass">
                                @if (item != null)
                                {
                                    <!-- Drink button: only for Healing Potion (slot 7) -->
                                    @if (i == 7)
                                    {
                                        var si = i;
                                        <button class="fw-inv-action fw-inv-drink" @onclick="DrinkHealingPotion">DRINK</button>
                                    }
                                    <span class="fw-inv-icon">@((MarkupString)item.Icon)</span>
                                    @if (slotWear > 0f)
                                    {
                                        <div class="fw-wear-bar">
                                            <div class="fw-wear-fill" style="width:@((int)(slotWear * 100))%;"></div>
                                        </div>
                                    }
                                    <!-- Drop button: all slots except pack (slot 0) -->
                                    @if (i != 0)
                                    {
                                        var di = i;
                                        <button class="fw-inv-action fw-inv-drop" @onclick="() => DropItem(di)">DROP</button>
                                    }
                                    <div class="fw-inv-tip">
                                        <div class="fw-inv-tip-name">@item.Name</div>
                                        @if (item.PackContents != null)
                                        {
                                            <div class="fw-inv-tip-pack-label">CONTENTS:</div>
                                            @foreach (var pc in item.PackContents)
                                            {
                                                <div class="fw-inv-tip-pack-item">&#183; @pc</div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="fw-inv-tip-desc">@item.Desc</div>
                                            <div class="fw-inv-tip-uses">Uses: @item.Uses</div>
                                            @if (item.IsAmmo)
                                            {
                                                <div class="fw-inv-tip-uses">Ammo: @item.AmmoCount</div>
                                            }
                                            @if (slotWear > 0f)
                                            {
                                                <div class="fw-inv-tip-uses">Wear: @((int)(slotWear * 100))%</div>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

            </div><!-- /fw-top -->

            <!-- ── BOTTOM SECTION: Area interaction ───────────────────── -->
            <div class="fw-bottom">
                <div class="fw-terrain-bg fw-terrain-@GetTerrainClass()"></div>

                <div class="fw-breadcrumb">
                    @for (var i = 0; i < areaPath.Count; i++)
                    {
                        var idx = i;
                        if (i > 0) { <span class="fw-crumb-sep">&#8250;</span> }
                        if (i < areaPath.Count - 1)
                        {
                            <span class="fw-crumb-link" @onclick="() => NavigateToCrumb(idx)">@areaPath[i]</span>
                        }
                        else
                        {
                            <span class="fw-crumb-current">@areaPath[i]</span>
                        }
                    }
                </div>

                <div class="fw-bottom-content">

                    <!-- ── Area body ──────────────────────────────────── -->
                    <div class="fw-area-body">
                        @{
                            var curInfo = GetCurrentAreaInfo();
                        }
                        @{
                            var playerGoalId = mapRows[playerPos.Row].QuestGoals[playerPos.Col];
                            var playerQuest  = playerGoalId != null ? activeQuests.FirstOrDefault(q => q.Id == playerGoalId) : null;
                        }

                        <!-- Pending skill check (intercepts map movement) -->
                        @if (pendingSkillCheckTarget != null)
                        {
                            var checkTarget = pendingSkillCheckTarget.Value;
                            var checkInfo   = mapRows[checkTarget.Row].Slots[checkTarget.Col].HasValue
                                ? GetAreaInfo(mapRows[checkTarget.Row].Slots[checkTarget.Col]!.Value) : null;
                            <div class="fw-skill-check-box">
                                <div class="fw-skill-check-title">&#9760; SKILL CHECK — @(checkInfo?.Name.ToUpper() ?? "AREA")</div>
                                <div class="fw-skill-check-desc">The terrain demands a test of your abilities. Choose how to proceed:</div>
                                <div class="fw-skill-check-btns">
                                    @foreach (var key in pendingSkillCheckOptions ?? [])
                                    {
                                        var sk = skills.FirstOrDefault(s => s.Key == key);
                                        if (sk != null)
                                        {
                                            var k = key;
                                            <button class="fw-btn" @onclick="() => TrySkillCheck(k)">@sk.Name</button>
                                        }
                                    }
                                    <button class="fw-btn fw-btn-leave" @onclick="CancelSkillCheck">TURN BACK</button>
                                </div>
                            </div>
                        }

                        @if (areaPath.Count == 1 && curInfo != null)
                        {
                            <div class="fw-area-info">
                                <div class="fw-area-icon" style="color:@curInfo.IconColor;">
                                    @((MarkupString)curInfo.Icon)
                                </div>
                                <div class="fw-area-text">
                                    <div class="fw-area-name">@curInfo.Name.ToUpper()</div>
                                    <div class="fw-area-desc">@curInfo.Description</div>

                                    <!-- Downtime indicator -->
                                    @if (downtimeSlots.ContainsKey((playerPos.Row, playerPos.Col)))
                                    {
                                        <div class="fw-downtime-indicator">&#9962; Shelter available &mdash; downtime possible</div>
                                        <button class="fw-btn fw-btn-downtime" @onclick="DoDowntime">TAKE DOWNTIME</button>
                                    }

                                    <!-- Quest goal completion -->
                                    @if (playerQuest != null)
                                    {
                                        <div class="fw-quest-complete">
                                            &#10003; @playerQuest.CompletionText
                                            <button class="fw-btn fw-btn-leave" @onclick="CompleteCurrentQuestGoal">COMPLETE QUEST (+@playerQuest.XpReward XP)</button>
                                        </div>
                                    }

                                    <!-- Sub-areas -->
                                    @if (currentSubAreas.Count > 0)
                                    {
                                        <div class="fw-subareas">
                                            @foreach (var sub in currentSubAreas)
                                            {
                                                var s = sub;
                                                <button class="fw-subarea-item" @onclick="() => EnterSubArea(s)">
                                                    <span class="fw-subarea-icon" style="color:@s.IconColor;">@((MarkupString)s.Icon)</span>
                                                    <span class="fw-subarea-name">@s.Name</span>
                                                    <span class="fw-subarea-action">@s.ActionLabel</span>
                                                </button>
                                            }
                                        </div>
                                    }

                                    <!-- Usable skill buttons -->
                                    @{
                                        var usableSkills = skills.Where(sk => IsSkillUsableHere(sk)).ToList();
                                    }
                                    @if (usableSkills.Count > 0)
                                    {
                                        <div class="fw-skill-buttons">
                                            @foreach (var sk in usableSkills)
                                            {
                                                var s = sk;
                                                <button class="fw-btn fw-skill-btn" @onclick="() => UseSkill(s)">@sk.Name</button>
                                            }
                                        </div>
                                    }

                                    <!-- Skill / action result -->
                                    @if (skillResultMessage != null)
                                    {
                                        <div class="fw-skill-result">@skillResultMessage</div>
                                    }
                                </div>
                            </div>
                        }
                        else if (areaPath.Count > 1 && activeSubArea != null)
                        {
                            <div class="fw-area-info">
                                <div class="fw-area-icon" style="color:@activeSubArea.IconColor;">
                                    @((MarkupString)activeSubArea.Icon)
                                </div>
                                <div class="fw-area-text">
                                    <div class="fw-area-name">@activeSubArea.Name.ToUpper()</div>
                                    <div class="fw-area-desc">@activeSubArea.Description</div>
                                    @if (pendingQuestOffer != null)
                                    {
                                        <div class="fw-quest-offer">
                                            <div class="fw-quest-offer-title">QUEST OFFER: @pendingQuestOffer.Title.ToUpper()</div>
                                            <div class="fw-quest-offer-text">@pendingQuestOffer.Objective</div>
                                            <div class="fw-quest-offer-btns">
                                                <button class="fw-btn" @onclick="AcceptQuest">ACCEPT</button>
                                                <button class="fw-btn" @onclick="DeclineQuest">DECLINE</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="fw-stub-text">[ deeper exploration &mdash; coming soon ]</p>
                                    }
                                    <button class="fw-btn fw-btn-leave" @onclick="() => NavigateToCrumb(0)">&#8592; LEAVE</button>
                                </div>
                            </div>
                        }
                    </div><!-- /fw-area-body -->

                    <!-- ── Journal ────────────────────────────────────── -->
                    <div class="fw-journal">
                        <div class="fw-journal-label">JOURNAL</div>

                        @if (activeQuests.Count == 0 && completedQuests.Count == 0 && failedQuests.Count == 0)
                        {
                            <div class="fw-journal-empty">No quests yet.</div>
                        }

                        @foreach (var q in activeQuests)
                        {
                            <div class="fw-journal-entry fw-jq-active" title="@q.Objective">
                                <span class="fw-journal-type">[<span class="@($"fw-qt-{q.Type.ToString().ToLower()}")">@q.Type.ToString()[..3].ToUpper()</span>]</span>
                                <span class="fw-journal-title">@q.Title</span>
                            </div>
                        }

                        @if (completedQuests.Count > 0 || failedQuests.Count > 0)
                        {
                            <button class="fw-journal-toggle" @onclick="() => journalExpanded = !journalExpanded">
                                @(journalExpanded ? "&#9650;" : "&#9660;") HISTORY (@(completedQuests.Count + failedQuests.Count))
                            </button>
                            @if (journalExpanded)
                            {
                                @foreach (var q in completedQuests)
                                {
                                    <div class="fw-journal-entry fw-jq-done" title="@q.CompletionText">
                                        <span class="fw-journal-type">[<span class="fw-qt-done">DON</span>]</span>
                                        <span class="fw-journal-title">@q.Title</span>
                                    </div>
                                }
                                @foreach (var q in failedQuests)
                                {
                                    <div class="fw-journal-entry fw-jq-failed" title="Quest lost — moved past the goal.">
                                        <span class="fw-journal-type">[<span class="fw-qt-fail">FAI</span>]</span>
                                        <span class="fw-journal-title">@q.Title</span>
                                    </div>
                                }
                            }
                        }
                    </div><!-- /fw-journal -->

                </div><!-- /fw-bottom-content -->
            </div><!-- /fw-bottom -->

        </div><!-- /fw-main -->

        <!-- ── STATUS BAR ─────────────────────────────────────────────── -->
        <div class="fw-status-bar">
            <div class="fw-sb-xp-wrap">
                <span class="fw-sb-label">XP</span>
                <div class="fw-sb-track">
                    <div class="fw-sb-fill" style="width:@XpPct%;"></div>
                </div>
                <span class="fw-sb-nums">@xpCurrent&thinsp;/&thinsp;@xpNext</span>
            </div>
            <div class="fw-sb-level">LVL&nbsp;@charLevel</div>
            <div class="fw-sb-statuses">
                @foreach (var s in statuses)
                {
                    <span class="fw-sb-status" title="@s.Label">@s.Icon</span>
                }
            </div>
        </div>

    }<!-- /else (logged in) -->

</div><!-- /forward-page -->

