    // ── State ──────────────────────────────────────────────────────────
    private bool               initialized;
    private MapRow[]           mapRows         = [];
    private (int Row, int Col) playerPos;
    private List<string>       areaPath        = [];
    private List<SubArea>      currentSubAreas = [];
    private SubArea?           activeSubArea;
    private InvItem?[]         invItems        = new InvItem?[12];
    private StatusEffect[]     statuses        = [];
    private List<Skill>        skills          = [];
    private List<Quest>        activeQuests    = [];
    private List<Quest>        completedQuests = [];
    private Quest?             pendingQuestOffer;
    private HashSet<string>         placedQuestGoals    = [];
    private int                     rowsTraveled        = 0;
    private Dictionary<string, int> questAcceptedAtRow  = [];
    private string?                 questMessage;
    private bool                    mapIsSliding        = false;
    private HashSet<(int Row, int Col)> visitedSlots    = [];
    private HashSet<(int Row, int Col)> seenSlots       = [];

    private string charName  = "Traveler";
    private int    charLevel = 1;
    private int    xpCurrent = 0;
    private int    xpNext    = 100;

    private int XpPct => xpNext > 0 ? (int)(xpCurrent * 100.0 / xpNext) : 0;

    // ── Lifecycle ──────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        UserSession.OnChange += HandleUserChanged;

