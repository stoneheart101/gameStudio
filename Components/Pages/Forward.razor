    // ── Map generation ─────────────────────────────────────────────────
    private void GenerateMap()
    {
        var rng = new Random();

        // 1. Pick 10 random slot positions
        var all = Enumerable.Range(0, 3)
            .SelectMany(r => Enumerable.Range(0, 5).Select(c => (R: r, C: c)))
            .ToList();
        var chosen = all.OrderBy(_ => rng.Next()).Take(10).ToHashSet();

        // 2. Guarantee bottom row and starting position
        if (!chosen.Any(p => p.R == 2)) chosen.Add((2, rng.Next(5)));
        var bottomSlots = chosen.Where(p => p.R == 2).ToList();
        var start       = bottomSlots[rng.Next(bottomSlots.Count)];
        playerPos       = (start.R, start.C);
        visitedSlots    = [playerPos];
        seenSlots       = [];

        // 3. Ensure rows 0 and 1 each have at least one area for forward movement
        if (!chosen.Any(p => p.R == 0)) chosen.Add((0, rng.Next(5)));
        if (!chosen.Any(p => p.R == 1)) chosen.Add((1, rng.Next(5)));

        // 4. Determine per-row offsets
        var offsets = new bool[3];
        for (var i = 0; i < 3; i++) offsets[i] = rng.Next(2) == 1;

        // 5. Assign base area types
        var typeGrid = new AreaType?[3, 5];
        foreach (var (r, c) in chosen)
            typeGrid[r, c] = BaseAreaPool[rng.Next(BaseAreaPool.Length)];

        // 6. Deep upgrade pass — a slot becomes deep if ALL filled neighbours
        //    share the same base type (offset-aware adjacency)
        (int S, int E) CssRange(int row, int col) =>
            offsets[row] ? (col * 2 + 2, col * 2 + 3) : (col * 2 + 1, col * 2 + 2);

        bool AreAdj(int r1, int c1, int r2, int c2)
        {
            if (r1 == r2) return Math.Abs(c1 - c2) == 1;
            if (Math.Abs(r1 - r2) != 1) return false;
            var (s1, e1) = CssRange(r1, c1);
            var (s2, e2) = CssRange(r2, c2);
            return s1 <= e2 && s2 <= e1;
        }

        foreach (var (r, c) in chosen.OrderBy(_ => rng.Next()))
        {
            if (typeGrid[r, c] is not AreaType t) continue;
            if (GetDeepType(t) is not AreaType deepT) continue;
            var neighbours = chosen
                .Where(n => (n.R != r || n.C != c) && AreAdj(r, c, n.R, n.C))
                .ToList();
            var matchingCount = neighbours.Count(n =>
                typeGrid[n.R, n.C].HasValue &&
                GetBaseType(typeGrid[n.R, n.C]!.Value) == t);
            if (matchingCount >= 2 && rng.Next(3) == 0)
            {
                typeGrid[r, c] = deepT;
            }
        }

        // 7. Build mapRows
        mapRows = Enumerable.Range(0, 3).Select(r =>
            new MapRow(
                IsOffset: offsets[r],
                Slots: Enumerable.Range(0, 5)
                    .Select(c => chosen.Contains((r, c)) ? typeGrid[r, c] : null)
                    .ToArray(),
                QuestGoals: new string?[5]
            )
        ).ToArray();

        // 8. Reachability-based dead-end prevention
        // Only ensure the player's reachable path forward never dead-ends.
        // Unreachable areas are allowed to dead-end.
        var row2Reach = GetHorizontallyReachable(mapRows[2].Slots, new[] { playerPos.Col });

        // Which row-1 slots are vertically reachable from row-2 reachable slots?
        var row1Direct = new HashSet<int>();
        foreach (var bc in row2Reach)
            for (var mc = 0; mc < 5; mc++)
                if (mapRows[1].Slots[mc].HasValue &&
                    AreVertAdjStatic(mapRows[1].IsOffset, mc, mapRows[2].IsOffset, bc))
                    row1Direct.Add(mc);
        var row1Reach = GetHorizontallyReachable(mapRows[1].Slots, row1Direct);

        // Ensure the player can reach row 1 at all
        if (row1Reach.Count == 0)
        {
            var fc = row2Reach.First();
            mapRows[1].Slots[fc] = BaseAreaPool[rng.Next(BaseAreaPool.Length)];
            row1Reach = GetHorizontallyReachable(mapRows[1].Slots, new[] { fc });
        }

        // For every reachable row-1 slot, ensure a connection exists to row 0
        foreach (var mc in row1Reach)
        {
            var hasUp = Enumerable.Range(0, 5).Any(tc =>
                mapRows[0].Slots[tc].HasValue &&
                AreVertAdjStatic(mapRows[0].IsOffset, tc, mapRows[1].IsOffset, mc));
            if (!hasUp)
                mapRows[0].Slots[mc] = BaseAreaPool[rng.Next(BaseAreaPool.Length)];
        }

        UpdateSeenSlots();
    }

    private static HashSet<int> GetHorizontallyReachable(AreaType?[] row, IEnumerable<int> startCols)
    {
        var result = new HashSet<int>();
        var queue  = new Queue<int>();
        foreach (var c in startCols)
            if (c >= 0 && c < 5 && row[c].HasValue && result.Add(c))
                queue.Enqueue(c);
        while (queue.Count > 0)
        {
            var col = queue.Dequeue();
            foreach (var nc in new[] { col - 1, col + 1 })
                if (nc >= 0 && nc < 5 && row[nc].HasValue && result.Add(nc))
                    queue.Enqueue(nc);
        }
        return result;
    }

    private static AreaType? GetDeepType(AreaType t) => t switch
    {
        AreaType.Forest  => AreaType.DeepForest,
        AreaType.Desert  => AreaType.DeepDesert,
        AreaType.Swamp   => AreaType.DeepSwamp,
        _ => null
    };

    private static AreaType GetBaseType(AreaType t) => t switch
    {
        AreaType.DeepForest => AreaType.Forest,
        AreaType.DeepDesert => AreaType.Desert,
        AreaType.DeepSwamp  => AreaType.Swamp,
        _ => t
    };

    // ── Movement helpers ───────────────────────────────────────────────
    // Returns CSS grid column range [start, end] for a slot, accounting for row offset.
    // Non-offset row, slot c  → CSS cols [2c+1, 2c+2]
    // Offset row, slot c      → CSS cols [2c+2, 2c+3]
    // Two slots in adjacent rows are visually adjacent when their ranges overlap.
    private (int Start, int End) GetCssColRange(int row, int col) =>
        mapRows[row].IsOffset
            ? (col * 2 + 2, col * 2 + 3)
            : (col * 2 + 1, col * 2 + 2);

    private bool AreVerticallyAdjacent(int r1, int c1, int r2, int c2)
    {
        var (s1, e1) = GetCssColRange(r1, c1);
        var (s2, e2) = GetCssColRange(r2, c2);
        return s1 <= e2 && s2 <= e1;
    }

    private static bool AreVertAdjStatic(bool r1IsOffset, int c1, bool r2IsOffset, int c2)
    {
        int s1 = r1IsOffset ? c1 * 2 + 2 : c1 * 2 + 1;
        int s2 = r2IsOffset ? c2 * 2 + 2 : c2 * 2 + 1;
        return s1 <= s2 + 1 && s2 <= s1 + 1;
    }

    private bool IsFilledSlot(int row, int col) =>
        row >= 0 && row < mapRows.Length &&
        col >= 0 && col < 5 &&
        mapRows[row].Slots[col].HasValue;

    private bool IsValidMove(int row, int col)
    {
        if (!IsFilledSlot(row, col)) return false;
        // Horizontal — same row, one column left or right
        if (row == playerPos.Row && Math.Abs(col - playerPos.Col) == 1) return true;
        // Upward — one row above, visually overlapping (handles offset rows correctly)
        if (row == playerPos.Row - 1)
            return AreVerticallyAdjacent(playerPos.Row, playerPos.Col, row, col);
        return false;
    }

    private bool IsVisible(int r, int c) => seenSlots.Contains((r, c));

    private void UpdateSeenSlots()
    {
        for (var r = 0; r < mapRows.Length; r++)
            for (var c = 0; c < 5; c++)
                if (mapRows[r].Slots[c].HasValue && IsAdjacentToVisited(r, c))
                    seenSlots.Add((r, c));
    }

    private bool IsAdjacentToVisited(int r, int c)
    {
        if (visitedSlots.Contains((r, c))) return true;
        foreach (var (vr, vc) in visitedSlots)
        {
            if (vr == r && Math.Abs(vc - c) == 1) return true;
            if (Math.Abs(vr - r) == 1 && AreVertAdjStatic(mapRows[vr].IsOffset, vc, mapRows[r].IsOffset, c)) return true;
        }
        return false;
    }

    private async Task OnMapRectClick(int row, int col)
    {
        if (!IsValidMove(row, col)) return;

        // Check for entry skill requirement on the destination
        var destSlot = mapRows[row].Slots[col];
        if (destSlot.HasValue)
        {
            var check = GetEntrySkillCheck(destSlot.Value);
            if (check != null)
            {
                pendingSkillCheckTarget  = (row, col);
                pendingSkillCheckOptions = check;
                ResetAreaBreadcrumb();
                // Override areaPath to show skill check context without resetting pendingSkillCheck
                pendingSkillCheckTarget  = (row, col);
                pendingSkillCheckOptions = check;
                return;
            }
        }

        await DoMove(row, col);
    }

    private async Task DoMove(int row, int col)
    {
        newlyVisibleSlots.Clear();
        var movingUp = row < playerPos.Row;
        playerPos = (row, col);
        visitedSlots.Add((row, col));
        if (movingUp)
        {
            // Capture visible cols per row before the shift
            var preRow0Cols = seenSlots.Where(s => s.Row == 0).Select(s => s.Col)
                .Union(visitedSlots.Where(v => v.Row == 0).Select(v => v.Col)).ToHashSet();
            var preRow1Cols = seenSlots.Where(s => s.Row == 1).Select(s => s.Col)
                .Union(visitedSlots.Where(v => v.Row == 1).Select(v => v.Col)).ToHashSet();
            departingRow         = mapRows[2];
            departingVisibleCols = visitedSlots.Where(v => v.Row == 2).Select(v => v.Col)
                .Union(seenSlots.Where(s => s.Row == 2).Select(s => s.Col))
                .ToHashSet();
            ShiftMapUp(); // shifts map; populates newlyVisibleSlots
            // Old row 0 → new row 1, old row 1 → new row 2 — both slide down into position
            slidingDownSlots = preRow0Cols.Select(c => (Row: 1, Col: c))
                .Union(preRow1Cols.Select(c => (Row: 2, Col: c)))
                .ToHashSet();
            StateHasChanged();
            await Task.Delay(460); // 70ms delay + 360ms animation + small buffer
            slidingDownSlots.Clear();
            departingRow         = null;
            departingVisibleCols.Clear();
            // Wait for is-new-visible fade (0.38s delay + 0.5s duration)
            await Task.Delay(550);
            newlyVisibleSlots.Clear();
        }
        else
        {
            var prevSeen = new HashSet<(int, int)>(seenSlots);
            UpdateSeenSlots();
            newlyVisibleSlots = seenSlots.Except(prevSeen).ToHashSet();
        }
        ResetAreaBreadcrumb();
    }

    // ── Layer shift ────────────────────────────────────────────────────
    // On upward move: old middle → new bottom, old top → new middle,
    // fresh row → new top.  Player always lands at row 2.
    private void ShiftMapUp()
    {
        var rng = new Random();

        // Fail any active quest goals that are about to be lost in old row 2
        for (var ci = 0; ci < 5; ci++)
        {
            var goalId = mapRows[2].QuestGoals[ci];
            if (goalId == null) continue;
            var quest = activeQuests.FirstOrDefault(q => q.Id == goalId);
            if (quest == null) continue;
            activeQuests.Remove(quest);
            failedQuests.Add(quest);
            placedQuestGoals.Remove(quest.Id);
            questAcceptedAtRow.Remove(quest.Id);
        }

        // Shift visited and seen slots up one row; old row 2 drops off-screen
        var shiftedVisited = new HashSet<(int, int)>();
        foreach (var (vr, vc) in visitedSlots)
            if (vr < 2) shiftedVisited.Add((vr + 1, vc));
        visitedSlots = shiftedVisited;

        var shiftedSeen = new HashSet<(int, int)>();
        foreach (var (sr, sc) in seenSlots)
            if (sr < 2) shiftedSeen.Add((sr + 1, sc));
        seenSlots = shiftedSeen;

        // Shift downtime slots (row 2 drops off, rest shift down)
        var shiftedDowntime = new Dictionary<(int, int), bool>();
        foreach (var (k, v) in downtimeSlots)
            if (k.Item1 < 2) shiftedDowntime.Add((k.Item1 + 1, k.Item2), v);
        downtimeSlots = shiftedDowntime;

        var newMiddleSlots = (AreaType?[])mapRows[0].Slots.Clone();
        var newMiddleGoals = (string?[])mapRows[0].QuestGoals.Clone();
        var newBottomRow   = mapRows[1];
        var oldTopIsOffset = mapRows[0].IsOffset;
        var oldMidIsOffset = mapRows[1].IsOffset;

        // Compute which new-middle cols the player can reach from new-bottom
        var bottomReach = GetHorizontallyReachable(newBottomRow.Slots, new[] { playerPos.Col });
        var midDirect   = new HashSet<int>();
        foreach (var bc in bottomReach)
            for (var mc = 0; mc < 5; mc++)
                if (newMiddleSlots[mc].HasValue &&
                    AreVertAdjStatic(oldTopIsOffset, mc, oldMidIsOffset, bc))
                    midDirect.Add(mc);
        var mustConnect = GetHorizontallyReachable(newMiddleSlots, midDirect);

        rowsTraveled++;
        bool newTopIsOffset = rng.Next(2) == 1;
        var (newTopSlots, newTopGoals) = GenerateNewRow(rng, newTopIsOffset, mustConnect, oldTopIsOffset);

        mapRows = [
            new MapRow(newTopIsOffset, newTopSlots, newTopGoals),
            new MapRow(oldTopIsOffset, newMiddleSlots, newMiddleGoals),
            newBottomRow,
        ];

        playerPos = (2, playerPos.Col);
        var prevSeen = new HashSet<(int, int)>(seenSlots);
        UpdateSeenSlots();
        newlyVisibleSlots = seenSlots.Except(prevSeen).ToHashSet();
    }

    private (AreaType?[] Slots, string?[] Goals) GenerateNewRow(Random rng,
        bool newRowIsOffset = false, HashSet<int>? mustConnect = null, bool belowIsOffset = false)
    {
        var slots = new AreaType?[5];
        var goals = new string?[5];

        // Find the first unplaced quest and its distance from acceptance
        var unplaced = activeQuests.FirstOrDefault(q => !placedQuestGoals.Contains(q.Id));
        double questChance = 0;
        if (unplaced != null)
        {
            var dist = rowsTraveled - questAcceptedAtRow.GetValueOrDefault(unplaced.Id, rowsTraveled);
            questChance = Math.Min(0.80, 0.10 + dist * 0.10);
        }

        foreach (var c in Enumerable.Range(0, 5).OrderBy(_ => rng.Next()).Take(rng.Next(2, 5)))
        {
            slots[c] = BaseAreaPool[rng.Next(BaseAreaPool.Length)];
            if (unplaced != null && !placedQuestGoals.Contains(unplaced.Id) && goals[c] == null && rng.NextDouble() < questChance)
            {
                goals[c] = unplaced.Id;
                placedQuestGoals.Add(unplaced.Id);
            }
        }

        // Dead-end prevention: only for reachable (must-connect) cols from below
        if (mustConnect != null)
        {
            foreach (var bc in mustConnect)
            {
                var hasReachable = Enumerable.Range(0, 5).Any(nc =>
                    slots[nc].HasValue && AreVertAdjStatic(newRowIsOffset, nc, belowIsOffset, bc));
                if (!hasReachable)
                    slots[bc] = BaseAreaPool[rng.Next(BaseAreaPool.Length)];
            }
        }

        // Place downtime location if interval has elapsed
        if (ShouldPlaceDowntime())
        {
            var filled = Enumerable.Range(0, 5).Where(c => slots[c].HasValue).ToList();
            if (filled.Count > 0)
            {
                var dtCol = filled[rng.Next(filled.Count)];
                downtimeSlots[(0, dtCol)] = true; // new top row is row 0
                lastDowntimeLayer = rowsTraveled;
            }
        }

        return (slots, goals);
    }

    // ── Area info helpers ──────────────────────────────────────────────
    private static AreaInfo GetAreaInfo(AreaType t) =>
        AreaInfoMap.TryGetValue(t, out var ai) ? ai : AreaInfoMap[AreaType.Grass];

    private AreaInfo? GetCurrentAreaInfo()
    {
        var slot = mapRows[playerPos.Row].Slots[playerPos.Col];
        return slot.HasValue ? GetAreaInfo(slot.Value) : null;
    }

    private void ResetAreaBreadcrumb()
    {
        var info = GetCurrentAreaInfo();
        areaPath = info != null ? [info.Name] : ["Unknown Area"];
        activeSubArea = null;
        questMessage = null;
        skillResultMessage = null;
        restRepairMessage = null;
        pendingSkillCheckTarget = null;
        pendingSkillCheckOptions = null;
        GenerateSubAreas();
    }

    private void GenerateSubAreas()
    {
        var slot = mapRows[playerPos.Row].Slots[playerPos.Col];
        if (slot.HasValue && SubAreaPool.TryGetValue(slot.Value, out var pool))
        {
            var rng   = new Random();
            var count = Math.Min(rng.Next(1, 4), pool.Length);
            currentSubAreas = pool.OrderBy(_ => rng.Next()).Take(count).ToList();
        }
        else
        {
            currentSubAreas = [];
        }
    }

    private void EnterSubArea(SubArea sub)
    {
        activeSubArea = sub;
        areaPath.Add(sub.Name);
        pendingQuestOffer = null;
        TryOfferQuest(sub);
    }

    private string GetTerrainClass()
    {
        var slot = mapRows[playerPos.Row].Slots[playerPos.Col];
        return slot switch
        {
            AreaType.Grass                            => "grass",
            AreaType.Forest or AreaType.DeepForest    => "forest",
            AreaType.Lake                             => "lake",
            AreaType.Mountain or AreaType.Cliff       => "mountain",
            AreaType.Desert or AreaType.DeepDesert    => "desert",
            AreaType.Swamp or AreaType.DeepSwamp      => "swamp",
            _ => "default"
        };
    }

    // ── Breadcrumb navigation ──────────────────────────────────────────
    private void NavigateToCrumb(int idx)
    {
        if (idx >= 0 && idx < areaPath.Count)
        {
            areaPath = areaPath.Take(idx + 1).ToList();
            if (idx == 0) activeSubArea = null;
        }
    }

    // ── Quest system ───────────────────────────────────────────────────
    private void TryOfferQuest(SubArea sub)
    {
        string[] questGiverKeys = [
            "camp", "farm", "dock", "outpost", "shrine",
            "grove", "ruins", "oasis", "clearing", "lookout", "hollow", "temple",
        ];
        if (!questGiverKeys.Contains(sub.Key)) return;
        if (new Random().Next(3) != 0) return;

        var available = QuestPool.Where(q =>
            !activeQuests.Any(aq => aq.Id == q.Id) &&
            !completedQuests.Any(cq => cq.Id == q.Id)).ToArray();
        if (available.Length == 0) return;

        pendingQuestOffer = available[new Random().Next(available.Length)];
    }

    private void AcceptQuest()
    {
        if (pendingQuestOffer == null) return;
        activeQuests.Add(pendingQuestOffer);
        questAcceptedAtRow[pendingQuestOffer.Id] = rowsTraveled;
        // Destination appears on future rows as player travels further — not placed immediately
        pendingQuestOffer = null;
        questMessage = null;
    }

    private void DeclineQuest() => pendingQuestOffer = null;


    private void CompleteCurrentQuestGoal()
    {
        var goalId = mapRows[playerPos.Row].QuestGoals[playerPos.Col];
        if (goalId == null) return;
        var quest = activeQuests.FirstOrDefault(q => q.Id == goalId);
        if (quest == null) return;

        mapRows[playerPos.Row].QuestGoals[playerPos.Col] = null;
        placedQuestGoals.Remove(quest.Id);
        questAcceptedAtRow.Remove(quest.Id);
        activeQuests.Remove(quest);
        completedQuests.Add(quest);
        xpCurrent += quest.XpReward;
        CheckLevelUp();
        questMessage = $"QUEST COMPLETE: {quest.Title.ToUpper()} (+{quest.XpReward} XP)";
    }

    private void CheckLevelUp()
    {
        while (xpCurrent >= xpNext)
        {
            xpCurrent -= xpNext;
            charLevel++;
            xpNext = charLevel * 100;
        }
    }

    // ── Entry skill checks ─────────────────────────────────────────────
    private static string[]? GetEntrySkillCheck(AreaType t) => t switch
    {
        AreaType.Cliff => ["climb", "jump"],
        _ => null,
    };

    private async Task TrySkillCheck(string skillKey)
    {
        if (pendingSkillCheckTarget == null) return;
        var target = pendingSkillCheckTarget.Value;
        pendingSkillCheckTarget  = null;
        pendingSkillCheckOptions = null;

        var skill = skills.FirstOrDefault(s => s.Key == skillKey);
        if (skill == null) return;

        // Find item slot for skill (null means no item required)
        var itemSlot = GetSkillItemSlot(skill);
        var rng      = new Random();
        var wearPenalty = itemSlot.HasValue ? itemWear.GetValueOrDefault(itemSlot.Value, 0f) * 0.3f : 0f;
        var successChance = 0.70f - wearPenalty;
        var passed = rng.NextDouble() < successChance;

        // Apply wear to item used (ammo: consume 1; otherwise wear)
        if (itemSlot.HasValue)
        {
            var item = invItems[itemSlot.Value];
            if (item?.IsAmmo == true)
            {
                // TODO: decrement ammo count when ammo tracking is wired
            }
            else
            {
                itemWear[itemSlot.Value] = Math.Min(1f, itemWear.GetValueOrDefault(itemSlot.Value, 0f) + 0.15f);
            }
        }

        if (passed)
        {
            await DoMove(target.Row, target.Col);
        }
        else
        {
            skillResultMessage = $"The {GetAreaInfo(mapRows[target.Row].Slots[target.Col]!.Value).Name.ToLower()} resists your attempt. [REPERCUSSIONS — STUB]";
            // TODO: apply repercussions
        }
    }

    private void CancelSkillCheck()
    {
        pendingSkillCheckTarget  = null;
        pendingSkillCheckOptions = null;
    }

    // ── Skill usability ────────────────────────────────────────────────
    private bool IsSkillUsableHere(Skill sk)
    {
        // Combat skills not shown outside of combat (combat is not yet implemented)
        if (sk.Key is "strike_sword" or "thrust_dagger" or "loose_arrow" or "parry_shield") return false;
        // Hide: usable anywhere not in combat when at base area
        if (sk.Key == "hide") return areaPath.Count == 1;
        if (sk.Key == "haggle") return false; // needs a merchant — future
        // Forage: usable at base area only, not on cliffs / deep desert
        if (sk.Key == "forage")
        {
            if (areaPath.Count != 1) return false;
            var slot = mapRows[playerPos.Row].Slots[playerPos.Col];
            return slot is not (AreaType.Cliff or AreaType.Lake);
        }
        // Repair: usable at base area if any worn item exists
        if (sk.Key == "repair")
        {
            if (areaPath.Count != 1) return false;
            return itemWear.Any(kv => kv.Value > 0f);
        }
        // Rest: usable at base area with required resources
        if (sk.Key == "rest") return areaPath.Count == 1 && rationCount > 0 && waterskinFull && FindFirewoodSlot() != null;
        // Climb / Jump: only useful as skill-check choices — don't surface as general buttons
        if (sk.Key is "climb" or "jump") return false;
        return false;
    }

    private void UseSkill(Skill sk)
    {
        skillResultMessage = null;
        restRepairMessage  = null;
        switch (sk.Key)
        {
            case "forage":   DoForage();   break;
            case "repair":   DoRepair();   break;
            case "rest":     DoRest();     break;
            case "hide":     skillResultMessage = "You slip into cover and wait. Nothing stirs."; break;
        }
    }

    // ── Forage & Gather ────────────────────────────────────────────────
    private void DoForage()
    {
        var slot = mapRows[playerPos.Row].Slots[playerPos.Col];
        if (!slot.HasValue) return;
        var yield = GetForageYield(slot.Value);
        var rng   = new Random();
        var msgs  = new List<string>();

        // Food → add to rations in pack
        if (yield.Food && rng.NextDouble() > 0.25)
        {
            rationCount++;
            UpdatePackContents();
            msgs.Add("food (rations +1)");
        }

        // Water → refill waterskin in pack
        if (yield.Water && rng.NextDouble() > 0.30)
        {
            waterskinFull = true;
            UpdatePackContents();
            msgs.Add("water (waterskin refilled)");
        }

        // Firewood → place in first free inventory slot
        if (yield.Firewood && rng.NextDouble() > 0.20)
        {
            var freeSlot = FindFreeInvSlot();
            if (freeSlot.HasValue)
            {
                invItems[freeSlot.Value] = new InvItem(IconFirewood, "Firewood", "Dry wood for a campfire. One use.", "Fuel for Rest");
                msgs.Add("firewood");
            }
            else
            {
                msgs.Add("firewood (inventory full)");
            }
        }

        skillResultMessage = msgs.Count > 0
            ? $"Forage & Gather: {string.Join(", ", msgs)}."
            : "Forage & Gather: nothing found here.";
    }

    private static ForageYield GetForageYield(AreaType t) => t switch
    {
        AreaType.Grass      => new(Food: true,  Water: true,  Firewood: true),
        AreaType.Forest     => new(Food: true,  Water: true,  Firewood: true),
        AreaType.DeepForest => new(Food: true,  Water: true,  Firewood: true),
        AreaType.Lake       => new(Food: true,  Water: true,  Firewood: false),
        AreaType.Mountain   => new(Food: true,  Water: true,  Firewood: true),
        AreaType.Cliff      => new(Food: false, Water: false, Firewood: false),
        AreaType.Desert     => new(Food: true,  Water: false, Firewood: false),
        AreaType.DeepDesert => new(Food: false, Water: false, Firewood: false),
        AreaType.Swamp      => new(Food: true,  Water: false, Firewood: true),
        AreaType.DeepSwamp  => new(Food: false, Water: false, Firewood: true),
        _ => new(false, false, false),
    };

    // ── Repair & Maintain ──────────────────────────────────────────────
    private void DoRepair()
    {
        // Choose most-worn item and repair it (halve wear)
        if (!itemWear.Any(kv => kv.Value > 0f)) { skillResultMessage = "Nothing needs repair."; return; }
        var (slot, wear) = itemWear.OrderByDescending(kv => kv.Value).First();
        itemWear[slot] = wear / 2f;
        var name = invItems[slot]?.Name ?? "item";
        restRepairMessage = $"Repair & Maintain: {name} repaired ({(int)(wear * 100)}% → {(int)(wear / 2 * 100)}%).";
        skillResultMessage = restRepairMessage;
    }

    // ── Rest ───────────────────────────────────────────────────────────
    private void DoRest()
    {
        var fwSlot = FindFirewoodSlot();
        if (fwSlot == null)           { skillResultMessage = "Rest requires firewood (none in inventory)."; return; }
        if (rationCount <= 0)         { skillResultMessage = "Rest requires food (no trail rations).";       return; }
        if (!waterskinFull)           { skillResultMessage = "Rest requires water (waterskin is empty).";    return; }

        invItems[fwSlot.Value] = null; // consume firewood
        rationCount--;
        waterskinFull = false;
        UpdatePackContents();

        scratches = 0;

        string repairMsg = "";
        if (itemWear.Any(kv => kv.Value > 0f))
        {
            var (rSlot, wear) = itemWear.OrderByDescending(kv => kv.Value).First();
            itemWear[rSlot] = wear / 2f;
            var name = invItems[rSlot]?.Name ?? "item";
            repairMsg = $" {name} repaired.";
        }
        skillResultMessage = $"You rest through the night. All scratches healed.{repairMsg}";
    }

    // ── Helpers ────────────────────────────────────────────────────────
    private int? FindFreeInvSlot()
    {
        for (var i = 0; i < invItems.Length; i++)
            if (invItems[i] == null) return i;
        return null;
    }

    private int? FindFirewoodSlot()
    {
        for (var i = 0; i < invItems.Length; i++)
            if (invItems[i]?.Name == "Firewood") return i;
        return null;
    }

    private void UpdatePackContents()
    {
        invItems[0] = new InvItem(IconPack, "Travelers Pack", "A sturdy canvas pack.", "Carry",
            PackContents: [
                $"Trail Rations ({rationCount} day{(rationCount == 1 ? "" : "s")})",
                "Basic Tool Kit",
                "Flint & Steel",
                waterskinFull ? "Waterskin (full)" : "Waterskin (empty)",
                "Hemp Rope (50ft)",
                "3 Torches",
                "20 Silver Coins",
            ]);
    }

    private void DropItem(int slot)
    {
        if (slot == 0) return; // can't drop Traveler's Pack
        invItems[slot] = null;
        itemWear.Remove(slot);
    }

    // ── Downtime ───────────────────────────────────────────────────────
    private void DoDowntime()
    {
        // TODO: check player is in a downtime location
        wounds     = 0;
        scratches  = 0;
        skillResultMessage = "Downtime taken. All wounds and scratches healed.";
    }

    // ── Health ─────────────────────────────────────────────────────────
    private void TakeScratch()
    {
        scratches++;
        if (scratches >= 3) { scratches = 0; TakeWound(); }
    }

    private void TakeWound()
    {
        wounds++;
        if (wounds >= 3) { playerDead = true; /* TODO: handle death */ }
    }

    private void DrinkHealingPotion()
    {
        if (invItems[7] == null) return;
        wounds = Math.Max(0, wounds - 1);
        scratches = 0;
        invItems[7] = null; // consumed
        skillResultMessage = "Healing Potion consumed: one wound healed, all scratches cleared.";
    }

    // ── Downtime slot generation ───────────────────────────────────────
    private bool ShouldPlaceDowntime() =>
        rowsTraveled > 0 && (rowsTraveled - lastDowntimeLayer) >= DowntimeInterval;

    // Helper: find item slot index for a skill's RequiredItem
    private int? GetSkillItemSlot(Skill sk)
    {
        if (sk.RequiredItem == null) return null;
        for (var i = 0; i < invItems.Length; i++)
            if (invItems[i]?.Name == sk.RequiredItem) return i;
        return null;
    }

    private void HandleUserChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => UserSession.OnChange -= HandleUserChanged;
}
