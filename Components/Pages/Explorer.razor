    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        UserSession.OnChange += HandleUserChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized) return;
        _initialized = true;

        if (UserSession.CurrentUser == null)
            _gameState = GameState.NoUser;
        else
            await LoadCharacters();
        StateHasChanged();
    }

    private void HandleUserChanged() => _ = InvokeAsync(async () =>
    {
        if (UserSession.CurrentUser == null)
        {
            _gameState = GameState.NoUser;
            _character = null;
        }
        else
        {
            await LoadCharacters();
        }
        StateHasChanged();
    });

    private async Task LoadCharacters()
    {
        _characters = await CharacterService.GetCharactersAsync(UserSession.CurrentUser!.Id);
        _gameState = GameState.CharSelect;
    }

    public void Dispose() => UserSession.OnChange -= HandleUserChanged;

    // ── Character management ─────────────────────────────────────────────────
    private void ShowCharCreate()
    {
        _newCharName = "";
        _createError = "";
        _statAlloc = _statNames.ToDictionary(s => s, _ => 1);
        _gameState = GameState.CharCreate;
    }

    private void IncrementStat(string stat)
    {
        if (_statPointsRemaining > 0 && _statAlloc[stat] < 10) _statAlloc[stat]++;
    }

    private void DecrementStat(string stat)
    {
        if (_statAlloc[stat] > 1) _statAlloc[stat]--;
    }

    private async Task CreateCharacter()
    {
        var name = _newCharName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        if (_statPointsRemaining != 0) { _createError = "DISTRIBUTE ALL POINTS"; return; }
        if (_characters.Any(c => c.Name.Equals(name, StringComparison.OrdinalIgnoreCase)))
        {
            _createError = "NAME ALREADY TAKEN";
            return;
        }

        var c = await CharacterService.CreateCharacterAsync(
            UserSession.CurrentUser!.Id, name,
            _statAlloc["Speed"], _statAlloc["Strength"], _statAlloc["Smarts"],
            _statAlloc["Agility"], _statAlloc["Toughness"], _statAlloc["Magic"], _statAlloc["Health"]);
        _characters.Add(c);
        _newCharName = "";
        _createError = "";
        SelectCharacter(c);
    }

    private async Task OnCreateKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CreateCharacter();
    }

    private void SelectCharacter(Character c) { _character = c; StartGame(); }

    private async Task DeleteCharacterAsync(int id)
    {
        await CharacterService.DeleteCharacterAsync(id);
        _characters = await CharacterService.GetCharactersAsync(UserSession.CurrentUser!.Id);
        _deleteConfirmId = null;
    }

