@page "/explorer"
@rendermode InteractiveServer
@inject UserSession UserSession
@inject ScoreService ScoreService
@inject CharacterService CharacterService
@implements IDisposable

<PageTitle>Explorer</PageTitle>

@* ── Loading ── *@
@if (_gameState == GameState.Loading)
{
    <div class="explorer-notice">
        <div class="ex-notice-text">LOADING...</div>
    </div>
}

@* ── No User ── *@
else if (_gameState == GameState.NoUser)
{
    <div class="explorer-notice">
        <div class="ex-notice-icon">@SvgIcon("shield", 52)</div>
        <div class="ex-notice-text">THOU HAST NO PROFILE</div>
        <div class="ex-notice-sub">Create a player profile to begin your quest</div>
        <a href="/" class="ex-btn">@SvgIcon("arrow-left", 13) RETURN HOME</a>
    </div>
}

@* ── Character Select ── *@
else if (_gameState == GameState.CharSelect)
{
    <div class="explorer-charscreen">
        <div class="ex-screen-ornament">⚔</div>
        <div class="ex-screen-title">EXPLORER</div>
        <div class="ex-screen-divider"></div>
        <div class="ex-screen-subtitle">CHOOSE THY CHAMPION</div>

        @if (_characters.Count == 0)
        {
            <div class="ex-no-chars">No champions found in this realm</div>
        }
        else
        {
            <div class="ex-char-list">
                @foreach (var c in _characters)
                {
                    var character = c;
                    bool isConfirming = _deleteConfirmId == character.Id;
                    <div class="ex-char-card @(isConfirming ? "ex-char-card-deleting" : "")"
                         @onclick="() => { if (!isConfirming) SelectCharacter(character); }">
                        @if (isConfirming)
                        {
                            <span class="ex-char-delete-prompt">DELETE @character.Name.ToUpper()?</span>
                            <div class="ex-char-delete-btns" @onclick:stopPropagation>
                                <button class="ex-btn ex-btn-danger ex-btn-sm" @onclick="() => DeleteCharacterAsync(character.Id)">
                                    @SvgIcon("x", 11) YES
                                </button>
                                <button class="ex-btn ex-btn-sm" @onclick="() => _deleteConfirmId = null">
                                    CANCEL
                                </button>
                            </div>
                        }
                        else
                        {
                            <span class="ex-char-card-icon">@SvgIcon("user", 18)</span>
                            <span class="ex-char-card-name">@character.Name.ToUpper()</span>
                            <span class="ex-char-card-stats">HP:@character.MaxHitPoints</span>
                            @SvgIcon("arrow-left", 13, "ex-char-card-arrow")
                            <button class="ex-char-delete-btn" @onclick:stopPropagation
                                    @onclick="() => _deleteConfirmId = character.Id"
                                    title="Delete champion">
                                @SvgIcon("x", 11)
                            </button>
                        }
                    </div>
                }
            </div>
        }

        <div class="ex-btn-row">
            <button class="ex-btn ex-btn-gold" @onclick="ShowCharCreate">
                @SvgIcon("circle-plus", 13) FORGE NEW CHAMPION
            </button>
            <a href="/" class="ex-btn">
                @SvgIcon("house", 13) RETREAT TO TOWN
            </a>
        </div>
    </div>
}

@* ── Character Create ── *@
else if (_gameState == GameState.CharCreate)
{
    <div class="explorer-charscreen">
        <div class="ex-screen-ornament">⚔</div>
        <div class="ex-screen-title">FORGE A CHAMPION</div>
        <div class="ex-screen-divider"></div>
        <div class="ex-screen-subtitle">ENTER THY NAME</div>

        <input class="ex-input"
               @bind="_newCharName"
               @bind:event="oninput"
               maxlength="20"
               placeholder="CHAMPION NAME..."
               @onkeydown="OnCreateKeyDown" />

        <div class="ex-screen-subtitle" style="margin-top:12px;">DISTRIBUTE THY ATTRIBUTES</div>
        <div class="ex-screen-subtitle" style="font-size:7px; color:var(--ex-stone);">
            POINTS REMAINING: <span style="color:@(_statPointsRemaining == 0 ? "var(--ex-gold)" : "#e05050")">@_statPointsRemaining</span> / @TotalStatPoints
        </div>

        <div class="ex-stat-alloc">
            @foreach (var stat in _statNames)
            {
                var s = stat;
                var val = _statAlloc[s];
                <div class="ex-stat-alloc-row">
                    <span class="ex-stat-alloc-label">@s.ToUpper()</span>
                    <button class="ex-stat-btn" @onclick="() => DecrementStat(s)" disabled="@(val <= 1)">−</button>
                    <span class="ex-stat-alloc-val">@val</span>
                    <button class="ex-stat-btn" @onclick="() => IncrementStat(s)" disabled="@(_statPointsRemaining <= 0)">+</button>
                    <div class="ex-stat-alloc-bar">
                        <div class="ex-stat-alloc-fill" style="width:@(val * 100 / 10)%"></div>
                    </div>
                </div>
            }
        </div>

        <div class="ex-stat-preview">
            HIT POINTS: <span class="ex-stat-hp">@(_statAlloc["Health"] * 5 + _statAlloc["Toughness"])</span>
        </div>

        @if (_createError != "")
        {
            <div class="ex-error">@SvgIcon("x", 11) @_createError</div>
        }

        <div class="ex-btn-row">
            <button class="ex-btn ex-btn-gold" @onclick="CreateCharacter"
                    disabled="@(string.IsNullOrWhiteSpace(_newCharName) || _statPointsRemaining != 0)">
                @SvgIcon("sword", 13) CREATE
            </button>
            <button class="ex-btn" @onclick="() => _gameState = GameState.CharSelect">
                @SvgIcon("arrow-left", 13) BACK
            </button>
        </div>
    </div>
}

@* ── Playing (includes inline challenge & combat in right panel) ── *@
else if (_gameState == GameState.Playing && _character != null)
{
    <div class="explorer-container">
        <!-- Header -->
        <div class="explorer-header">
            <div class="ex-header-menu">
                <a href="/" class="ex-btn ex-btn-sm">
                    @SvgIcon("house", 12) HOME
                </a>
                <button class="ex-btn ex-btn-sm" @onclick="() => _showNewGameConfirm = true">
                    @SvgIcon("rotate-ccw", 12) NEW GAME
                </button>
            </div>
            <span class="explorer-title">EXPLORER</span>
            <span class="explorer-header-tiles">
                @SvgIcon("compass", 11) @_tilesVisited TILES
            </span>
            <span class="explorer-header-char">
                @SvgIcon("user", 11) @_character.Name.ToUpper()
            </span>
        </div>

        <!-- Main three-column area -->
        <div class="explorer-main">

            <!-- Left: Stats + Inventory + Minimap -->
            <div class="explorer-left">
                <div class="explorer-stats">
                    <div class="explorer-panel-title">@SvgIcon("scroll", 10) @_character.Name.ToUpper()</div>
                    <!-- HP bar -->
                    <div class="explorer-stat-label" style="margin-bottom:4px;">HIT POINTS</div>
                    <div class="ex-play-hp-bar">
                        <div class="ex-play-hp-fill" style="width:@(Math.Max(0, _playerHp * 100 / Math.Max(1, _playerMaxHp)))%"></div>
                    </div>
                    <span class="ex-play-hp-text">@_playerHp / @_playerMaxHp</span>
                    <!-- 2-column stat table -->
                    <div class="explorer-stat-table">
                        <div class="explorer-stat-row2"><span class="explorer-stat-label2">SPEED</span><span class="explorer-stat-val2">@_character.Speed</span></div>
                        <div class="explorer-stat-row2"><span class="explorer-stat-label2">STRENGTH</span><span class="explorer-stat-val2">@_character.Strength</span></div>
                        <div class="explorer-stat-row2"><span class="explorer-stat-label2">SMARTS</span><span class="explorer-stat-val2">@_character.Smarts</span></div>
                        <div class="explorer-stat-row2"><span class="explorer-stat-label2">AGILITY</span><span class="explorer-stat-val2">@_character.Agility</span></div>
                        <div class="explorer-stat-row2"><span class="explorer-stat-label2">TOUGHNESS</span><span class="explorer-stat-val2">@_character.Toughness</span></div>
                        <div class="explorer-stat-row2"><span class="explorer-stat-label2">MAGIC</span><span class="explorer-stat-val2">@_character.Magic</span></div>
                        <div class="explorer-stat-row2"><span class="explorer-stat-label2">HEALTH</span><span class="explorer-stat-val2">@_character.Health</span></div>
                    </div>
                </div>

                <div class="explorer-inventory">
                    <div class="explorer-panel-title">@SvgIcon("shield", 10) INVENTORY</div>
                    <div class="inventory-grid">
                        @for (int i = 0; i < 10; i++)
                        {
                            var item = i < _inventory.Count ? _inventory[i] : null;
                            var isConsumable = !_activeCombat && !_activeChallenge && item?.Name == "Healing Potion";
                            <div class="inv-slot @(item != null ? "inv-slot-filled" : "") @(isConsumable ? "inv-slot-usable" : "")"
                                 title="@(isConsumable ? "Click to use — " + GetItemTooltip(item) : GetItemTooltip(item))"
                                 @onclick="() => { if (isConsumable && item != null) UseItemOutOfCombat(item); }">
                                @if (item != null)
                                {
                                    @SvgIcon(item.Icon, 18)
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Minimap -->
                <div class="explorer-minimap">
                    <div class="explorer-panel-title">@SvgIcon("compass", 10) MAP</div>
                    <div class="minimap-canvas">
                        <div class="minimap-grid" style="grid-template-columns:repeat(@MinimapSize, 5px); grid-template-rows:repeat(@MinimapSize, 5px);">
                            @for (int my = 0; my < MinimapSize; my++)
                            {
                                @for (int mx = 0; mx < MinimapSize; mx++)
                                {
                                    var worldX = _playerX - MinimapSize / 2 + mx;
                                    var worldY = _playerY - MinimapSize / 2 + my;
                                    var isPlayerMm = (worldX == _playerX && worldY == _playerY);
                                    var mmTile = GetDisplayTile(worldX, worldY);
                                    var mmClass = isPlayerMm ? "mm-player" :
                                        (mmTile?.Visited == true ? $"mm-{mmTile.Type.ToString().ToLower()}" :
                                         (mmTile?.Type == TileType.Water ? "mm-water-fog" :
                                          (mmTile?.Type == TileType.Mountain ? "mm-mountain-fog" : "mm-empty")));
                                    <div class="mm-cell @mmClass"></div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Center: 9×9 Map -->
            <div class="explorer-map-area">
                <div class="map-grid">
                    @for (int row = -4; row <= 4; row++)
                    {
                        @for (int col = -4; col <= 4; col++)
                        {
                            var tx = _playerX + col;
                            var ty = _playerY + row;
                            bool isPlayer = (tx == _playerX && ty == _playerY);
                            bool isAdjacent = !isPlayer && Math.Abs(col) <= 1 && Math.Abs(row) <= 1;
                            var tile = GetDisplayTile(tx, ty);
                            string tileClass = BuildTileClass(tile, isPlayer, isAdjacent);

                            <div class="@tileClass"
                                 title="@GetTileTooltip(tile, isPlayer)"
                                 @onclick="() => OnTileClickAsync(tx, ty)">
                                @if (isPlayer)
                                {
                                    @TileIconSvg(GetDisplayTile(_playerX, _playerY)?.Type ?? TileType.Grassland)
                                }
                                else if (tile?.Visited == true)
                                {
                                    @TileIconSvg(tile.Type)
                                    @if (tile.HasChallenge && !tile.ChallengeCleared)
                                    {
                                        <span class="tile-challenge-mark @(tile.RetreatedFrom ? "tile-challenge-retreated" : "")">
                                            @ChallengeTypeIcon(tile.Challenge?.Type)
                                        </span>
                                    }
                                }
                                else if (tile?.Revealed == true)
                                {
                                    @TileIconSvg(tile.Type)
                                    @if (tile.HasChallenge && !tile.ChallengeCleared && tile.RetreatedFrom)
                                    {
                                        <span class="tile-challenge-mark tile-challenge-retreated">
                                            @ChallengeTypeIcon(tile.Challenge?.Type)
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="tile-unknown-glyph">▓</span>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="map-coords">[@_playerX, @_playerY]</div>
            </div>

            <!-- Right: Location / Challenge / Combat panel -->
            <div class="explorer-location">
                @if (_activeCombat && _currentEnemy != null)
                {
                    <!-- ═══ COMBAT in right panel ═══ -->
                    <div class="explorer-panel-title">@SvgIcon("swords", 10) COMBAT</div>

                    <div class="rp-combat-enemy">
                        <span class="rp-combat-icon">@_currentEnemy.Icon</span>
                        <span class="rp-combat-name">@_currentEnemy.Name.ToUpper()</span>
                    </div>
                    <div class="rp-combat-hp-row">
                        <span class="rp-combat-hp-label">ENEMY</span>
                        <div class="combat-hp-bar"><div class="combat-hp-fill combat-hp-enemy" style="width:@(Math.Max(0, _currentEnemy.Hp * 100 / _currentEnemy.MaxHp))%"></div></div>
                        <span class="rp-combat-hp-num">@_currentEnemy.Hp/@_currentEnemy.MaxHp</span>
                    </div>
                    <div class="rp-combat-hp-row">
                        <span class="rp-combat-hp-label">YOU</span>
                        <div class="combat-hp-bar"><div class="combat-hp-fill" style="width:@(Math.Max(0, _playerHp * 100 / Math.Max(1, _playerMaxHp)))%"></div></div>
                        <span class="rp-combat-hp-num">@_playerHp/@_playerMaxHp</span>
                    </div>

                    <div class="rp-combat-log">
                        @foreach (var msg in _combatLog.Take(5))
                        {
                            <div class="rp-combat-log-entry">@msg</div>
                        }
                    </div>

                    @if (_combatOver)
                    {
                        <div class="rp-combat-result">@_combatResultMsg</div>
                        @if (_playerDead)
                        {
                            <div class="rp-death-score">SCORE: @_tilesVisited TILES EXPLORED</div>
                            <button class="ex-btn ex-btn-danger ex-btn-full" @onclick="EndCombatDeath">GAME OVER</button>
                        }
                        else
                        {
                            <button class="ex-btn ex-btn-gold ex-btn-full" @onclick="EndCombat">CONTINUE</button>
                        }
                    }
                    else
                    {
                        <div class="rp-combat-actions">
                            <button class="ex-btn ex-btn-gold ex-btn-full" @onclick='() => PlayerAttack("melee")'>
                                @SvgIcon("sword", 12) MELEE (@GetMeleeWeaponName())
                            </button>
                            @if (HasBow())
                            {
                                <button class="ex-btn ex-btn-gold ex-btn-full" @onclick='() => PlayerAttack("ranged")'>
                                    @SvgIcon("bow", 12) RANGED (Bow)
                                </button>
                            }
                            @if (HasHealingPotion())
                            {
                                <button class="ex-btn ex-btn-heal ex-btn-full" @onclick="UseHealingPotion">
                                    @SvgIcon("potion", 12) HEAL (+5 HP)
                                </button>
                            }
                            <button class="ex-btn ex-btn-full" @onclick="AttemptFlee">
                                @SvgIcon("arrow-left", 12) FLEE
                            </button>
                        </div>
                    }
                }
                else if (_activeChallenge && _currentChallenge != null)
                {
                    <!-- ═══ CHALLENGE in right panel ═══ -->
                    <div class="explorer-panel-title">@SvgIcon("swords", 10) CHALLENGE</div>

                    @if (_isExitChallenge)
                    {
                        <div class="rp-trapped-banner">
                            @SvgIcon("x", 11) TRAPPED — overcome this to move
                        </div>
                    }

                    <div class="rp-challenge-header">
                        <span class="rp-challenge-icon">@_currentChallenge.Icon</span>
                        <span class="rp-challenge-title">@_currentChallenge.Title</span>
                    </div>
                    <div class="rp-challenge-desc">@_currentChallenge.Description</div>

                    @if (_challengeResolved)
                    {
                        <div class="rp-challenge-result @(_challengeSuccess ? "challenge-success" : "challenge-fail")">
                            @_challengeResultMsg
                        </div>
                        <button class="ex-btn ex-btn-gold ex-btn-full" @onclick="EndChallenge">CONTINUE</button>
                    }
                    else if (_currentChallenge.Type == ChallengeType.StatCheck)
                    {
                        <div class="rp-challenge-info">
                            Requires: @_currentChallenge.StatName!.ToUpper() (yours: @GetCharStat(_character, _currentChallenge.StatName!))
                        </div>
                        <button class="ex-btn ex-btn-gold ex-btn-full" @onclick="AttemptStatCheck">
                            @SvgIcon("target", 12) ATTEMPT
                        </button>
                        @if (!_isExitChallenge && (_currentChallenge?.AllowRetreat ?? true))
                        {
                            <button class="ex-btn ex-btn-full" @onclick="RetreatFromChallenge">
                                @SvgIcon("arrow-left", 12) RETREAT
                            </button>
                        }
                    }
                    else if (_currentChallenge.Type == ChallengeType.Riddle)
                    {
                        <div class="rp-challenge-info">
                            Answer the riddle, or roll Smarts (@GetCharStat(_character!, "Smarts")) vs DC @(_currentChallenge.Difficulty + 10)
                        </div>
                        <input class="ex-input" style="margin:8px 0;"
                               @bind="_riddleAnswer"
                               @bind:event="oninput"
                               placeholder="ENTER ANSWER..."
                               @onkeydown="OnRiddleKeyDown" />
                        <button class="ex-btn ex-btn-gold ex-btn-full" @onclick="AttemptRiddle">
                            @SvgIcon("scroll", 12) ANSWER
                        </button>
                        <button class="ex-btn ex-btn-full" @onclick="AttemptRiddleStatRoll">
                            @SvgIcon("target", 12) ROLL WIT (SMARTS)
                        </button>
                        @if (!_isExitChallenge && (_currentChallenge?.AllowRetreat ?? true))
                        {
                            <button class="ex-btn ex-btn-full" @onclick="RetreatFromChallenge">
                                @SvgIcon("arrow-left", 12) RETREAT
                            </button>
                        }
                    }
                    else if (_currentChallenge.Type == ChallengeType.ItemRequired)
                    {
                        <div class="rp-challenge-info">
                            You need: @_currentChallenge.RequiredItemName
                        </div>
                        <button class="ex-btn ex-btn-gold ex-btn-full" @onclick="AttemptItemChallenge">
                            @SvgIcon("shield", 12) OFFER ITEM
                        </button>
                        @if (!_isExitChallenge && (_currentChallenge?.AllowRetreat ?? true))
                        {
                            <button class="ex-btn ex-btn-full" @onclick="RetreatFromChallenge">
                                @SvgIcon("arrow-left", 12) RETREAT
                            </button>
                        }
                    }
                    else if (_currentChallenge.Type == ChallengeType.Combat)
                    {
                        <button class="ex-btn ex-btn-gold ex-btn-full" @onclick="StartCombatChallenge">
                            @SvgIcon("swords", 12) FIGHT
                        </button>
                        @if (!_isExitChallenge && (_currentChallenge?.AllowRetreat ?? true))
                        {
                            <button class="ex-btn ex-btn-full" @onclick="RetreatFromChallenge">
                                @SvgIcon("arrow-left", 12) RETREAT
                            </button>
                        }
                    }
                }
                else
                {
                    <!-- ═══ Normal location info ═══ -->
                    <div class="explorer-panel-title">@SvgIcon("scroll", 10) LOCATION</div>
                    <div class="location-type-label">
                        @TileIconSvg(CurrentTileType) @CurrentTileType.ToString().ToUpper()
                    </div>
                    <div class="location-desc">@TileDescription(CurrentTileType)</div>

                    @if (_activeExitChallenge && CurrentTile?.ExitChallenge != null && !CurrentTile.ExitChallengeCleared)
                    {
                        <div class="location-trapped-notice">
                            @SvgIcon("x", 12) TRAPPED — You cannot leave this tile!
                        </div>
                        <div class="location-trapped-challenge">
                            <span class="location-trapped-icon">@CurrentTile.ExitChallenge.Icon</span>
                            @CurrentTile.ExitChallenge.Title
                        </div>
                        <div class="location-trapped-desc">@CurrentTile.ExitChallenge.Description</div>
                        <button class="ex-btn ex-btn-danger ex-btn-full" @onclick="TriggerExitChallenge">
                            @SvgIcon("swords", 12) ATTEMPT ESCAPE
                        </button>
                    }
                    else if (CurrentTile?.HasChallenge == true && !CurrentTile.ChallengeCleared)
                    {
                        <div class="location-challenge-notice">
                            @SvgIcon("swords", 12) A challenge awaits here!
                        </div>
                    }

                    <div class="location-actions">
                        <div class="explorer-panel-title">@SvgIcon("swords", 10) ACTIONS</div>
                        @if (_playerHp < _playerMaxHp)
                        {
                            var restHeal = Math.Max(1, (_playerMaxHp - _playerHp) / 2);
                            <button class="ex-btn ex-btn-rest ex-btn-full" @onclick="Rest">
                                @SvgIcon("moon", 12) REST (+@restHeal HP)
                            </button>
                        }
                        <div class="location-hint">
                            Click an adjacent tile to move there.
                            <br /><br />
                            Cliffs and Mountains must be navigated.
                            Water cannot be crossed.
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Status bar -->
        <div class="explorer-statusbar @(_statusExpanded ? "status-expanded" : "")">
            <div class="status-bar-row">
                <span class="status-last-msg">
                    @(_statusHistory.Count > 0 ? _statusHistory[0] : "Ready to explore.")
                </span>
                <button class="status-toggle-btn" @onclick="ToggleStatus">
                    @(_statusExpanded ? SvgIcon("chevron-up", 13) : SvgIcon("chevron-down", 13))
                </button>
            </div>
            @if (_statusExpanded && _statusHistory.Count > 1)
            {
                <div class="status-history-list">
                    @foreach (var msg in _statusHistory.Skip(1).Take(20))
                    {
                        <div class="status-history-entry">@msg</div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Confirm new game overlay -->
    @if (_showNewGameConfirm)
    {
        <div class="ex-confirm-overlay" @onclick="() => _showNewGameConfirm = false">
            <div class="ex-confirm-dialog" @onclick:stopPropagation>
                <div class="ex-confirm-title">BEGIN ANEW?</div>
                <div class="ex-confirm-text">
                    All progress for <strong>@_character.Name.ToUpper()</strong> will be lost.<br />
                    Choose a new champion to continue.
                </div>
                <div class="ex-confirm-btns">
                    <button class="ex-btn ex-btn-danger" @onclick="ConfirmNewGame">
                        @SvgIcon("rotate-ccw", 12) CONFIRM
                    </button>
                    <button class="ex-btn" @onclick="() => _showNewGameConfirm = false">
                        @SvgIcon("x", 12) CANCEL
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    // ── Game state enum ──────────────────────────────────────────────────────
    private enum GameState { Loading, NoUser, CharSelect, CharCreate, Playing }

    // ── Tile system ──────────────────────────────────────────────────────────
    private enum TileType { Forest, Grassland, Cliff, Water, Mountain }

    private class MapTile
    {
        public int X { get; set; }
        public int Y { get; set; }
        public TileType Type { get; set; }
        public bool Visited { get; set; }
        public bool Revealed { get; set; }
        public bool HasChallenge { get; set; }
        public bool ChallengeCleared { get; set; }
        public bool RetreatedFrom { get; set; }
        public Challenge? Challenge { get; set; }
        // Exit challenges block movement OUT of the tile
        public bool HasExitChallenge { get; set; }
        public bool ExitChallengeCleared { get; set; }
        public Challenge? ExitChallenge { get; set; }
    }

    // ── Inventory ────────────────────────────────────────────────────────────
    private record InventoryItem(string Name, string Icon, int Damage = 0, string Tooltip = "");

    // ── Challenge system ─────────────────────────────────────────────────────
    private enum ChallengeType { Combat, StatCheck, Riddle, ItemRequired }

    private class Challenge
    {
        public ChallengeType Type { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "⚡";
        public string? StatName { get; set; }
        public int Difficulty { get; set; }
        public string? RiddleAnswer { get; set; }
        public string? RequiredItemName { get; set; }
        public string? EnemyType { get; set; }
        public bool AllowRetreat { get; set; } = true;
    }

    // ── Enemy system ─────────────────────────────────────────────────────────
    private class Enemy
    {
        public string Name { get; set; } = "";
        public string Icon { get; set; } = "👹";
        public int Hp { get; set; }
