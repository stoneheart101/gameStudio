    private Challenge GenerateStatCheckChallenge(TileType type, int dist)
    {
        var (stat, title, desc) = type switch
        {
            TileType.Cliff => ("Agility", "TREACHEROUS CLIMB",
                "The cliff face is sheer and crumbling. You must climb with great care."),
            TileType.Forest => ("Smarts", "LOST IN THE WOODS",
                "The forest grows dense and confusing. You need wits to find the path."),
            _ => _rng.Next(2) == 0
                ? ("Strength", "FALLEN BOULDER",
                    "A massive boulder blocks the passage. You must push it aside.")
                : ("Agility", "NARROW LEDGE",
                    "A crumbling ledge is the only way forward. One wrong step means a fall.")
        };

        return new Challenge
        {
            Type = ChallengeType.StatCheck,
            Title = title, Description = desc, Icon = "💪",
            StatName = stat,
            Difficulty = Math.Min(8, 3 + dist / 2)
