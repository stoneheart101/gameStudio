    // ── Inventory helpers ────────────────────────────────────────────────────
    private string GetItemTooltip(InventoryItem? item)
    {
        if (item == null) return "Empty";
        if (!string.IsNullOrEmpty(item.Tooltip)) return item.Tooltip;
        return item.Damage > 0 ? $"{item.Name} — {item.Damage} damage" : item.Name;
    }

    private string GetMeleeWeaponName()
    {
        // Pick best melee weapon by damage
        var melee = _inventory.Where(i => i.Name == "Dagger" || i.Name == "Sword")
            .OrderByDescending(i => i.Damage).FirstOrDefault();
        return melee?.Name ?? "Fists";
    }

    private int GetMeleeWeaponDamage()
    {
        var melee = _inventory.Where(i => i.Name == "Dagger" || i.Name == "Sword")
            .OrderByDescending(i => i.Damage).FirstOrDefault();
        return melee?.Damage ?? 1;
    }

    private int GetBowDamage()
    {
        var bow = _inventory.FirstOrDefault(i => i.Name == "Bow");
        return bow?.Damage ?? 3;
    }

    private bool HasBow() => _inventory.Any(i => i.Name == "Bow");
    private bool HasHealingPotion() => _inventory.Any(i => i.Name == "Healing Potion");

    // ── Display helpers ──────────────────────────────────────────────────────
    private MapTile? GetDisplayTile(int x, int y)
    {
        _map.TryGetValue((x, y), out var tile);
        return tile;
    }

    private string BuildTileClass(MapTile? tile, bool isPlayer, bool isAdjacent)
    {
        if (isPlayer)
        {
            // Add terrain class to player tile for background color
            var pTile = GetDisplayTile(_playerX, _playerY);
            var terrainSuffix = pTile != null ? $" tile-type-{pTile.Type.ToString().ToLower()}" : "";
            return $"map-tile tile-player{terrainSuffix}";
        }

        var parts = new System.Text.StringBuilder("map-tile");

        if (tile == null || (!tile.Visited && !tile.Revealed))
        {
            parts.Append(" tile-unknown");
        }
        else if (tile.Visited)
        {
            parts.Append(" tile-visited tile-type-");
            parts.Append(tile.Type.ToString().ToLower());
            if (isAdjacent && !MovementLocked) parts.Append(" tile-adjacent");
            if (tile.HasChallenge && !tile.ChallengeCleared && tile.RetreatedFrom)
                parts.Append(" tile-retreated");
        }
        else
        {
            parts.Append(" tile-revealed tile-type-");
            parts.Append(tile.Type.ToString().ToLower());
            if (isAdjacent && tile.Type != TileType.Water && !MovementLocked)
                parts.Append(" tile-adjacent");
            if (tile.HasChallenge && !tile.ChallengeCleared && tile.RetreatedFrom)
                parts.Append(" tile-retreated");
        }

        return parts.ToString();
    }

    private static MarkupString TileIconSvg(TileType type) => SvgIcon(type switch
    {
        TileType.Forest    => "tree-pine",
        TileType.Grassland => "leaf",
        TileType.Cliff     => "mountain",
        TileType.Water     => "waves",
        TileType.Mountain  => "mountain-snow",
        _                  => "leaf"
    }, 18);

    private string GetTileTooltip(MapTile? tile, bool isPlayer)
    {
        if (isPlayer) return $"{_character?.Name ?? "You"} — current position";
        if (tile == null || (!tile.Visited && !tile.Revealed)) return "Unexplored";
        if (!tile.Visited) return $"{tile.Type} (unvisited)";
        if (tile.HasChallenge && !tile.ChallengeCleared && tile.RetreatedFrom)
        {
            var cType = tile.Challenge?.Type switch
            {
                ChallengeType.Combat => "Combat",
                ChallengeType.StatCheck => $"Skill check ({tile.Challenge?.StatName})",
                ChallengeType.Riddle => "Riddle",
                ChallengeType.ItemRequired => $"Requires {tile.Challenge?.RequiredItemName}",
                _ => "Challenge"
            };
            return $"{tile.Type} — Retreated: {cType}";
        }
        if (tile.HasChallenge && !tile.ChallengeCleared)
            return $"{tile.Type} — ⚠ Challenge ahead";
        return tile.Type.ToString();
    }

    private static string TileDescription(TileType type) => type switch
    {
        TileType.Forest    => "Dense trees surround you. Shafts of light pierce the canopy. The air smells of pine and earth.",
        TileType.Grassland => "Open plains stretch in all directions. A gentle breeze stirs the tall grass. Good ground to travel.",
        TileType.Cliff     => "Jagged rock faces rise sharply. Loose stones crumble underfoot. Every step demands care.",
        TileType.Water     => "Dark water stretches before you, too deep and cold to cross. You'll need to find another way.",
        TileType.Mountain  => "Towering peaks loom overhead, wreathed in mist and snow. The air is thin and the path treacherous.",
        _                  => "You stand here, taking in the surroundings."
    };

    // ── Movement ─────────────────────────────────────────────────────────────
    private void OnTileClickAsync(int tx, int ty)
    {
        if (_gameState != GameState.Playing || MovementLocked) return;
        if (tx == _playerX && ty == _playerY) return;
        if (Math.Abs(tx - _playerX) > 1 || Math.Abs(ty - _playerY) > 1) return;

        var tile = GetOrGenerateTile(tx, ty);

        if (tile.Type == TileType.Water)
        {
            PushStatus("The water is too deep to cross. You step back.");
            return;
        }

        if (tile.HasChallenge && !tile.ChallengeCleared)
        {
            _pendingMoveTo = (tx, ty);
            _currentChallenge = tile.Challenge;
            _challengeResolved = false;
            _challengeSuccess = false;
            _challengeResultMsg = "";
            _riddleAnswer = "";
            _activeChallenge = true;
            return;
        }

        MoveToTile(tx, ty, tile);
    }

    private void MoveToTile(int tx, int ty, MapTile tile)
    {
        switch (tile.Type)
        {
            case TileType.Cliff:    PushStatus("You scramble up the rocky cliff face."); break;
            case TileType.Forest:   PushStatus("You push through the dense undergrowth."); break;
            case TileType.Grassland: PushStatus("You stride across the open grassland."); break;
            case TileType.Mountain: PushStatus("You crest the mountain pass, breathing thin cold air."); break;
        }
        _playerX = tx;
        _playerY = ty;
        MarkVisited(tile);

        // Trigger exit challenge if present and not yet cleared — open challenge panel immediately
        if (tile.HasExitChallenge && !tile.ExitChallengeCleared)
        {
            _activeExitChallenge = true;
            _currentChallenge = tile.ExitChallenge;
            _challengeResolved = false;
            _challengeSuccess = false;
            _challengeResultMsg = "";
            _riddleAnswer = "";
            _isExitChallenge = true;
            _activeChallenge = true;
            PushStatus($"⚠ TRAPPED — \"{tile.ExitChallenge?.Title}\" holds you fast!");
        }
    }

    // ── Challenge resolution ─────────────────────────────────────────────────
    private void AttemptStatCheck()
    {
        if (_currentChallenge == null || _character == null) return;
        var statVal = GetCharStat(_character, _currentChallenge.StatName!);
        var roll = _rng.Next(1, 21);
        var total = roll + statVal;
        var dc = _currentChallenge.Difficulty + 10;

        if (total >= dc)
        {
            _challengeSuccess = true;
            _challengeResultMsg = $"Rolled {roll}+{statVal}={total} vs DC {dc}. SUCCESS!";
        }
        else
        {
            _challengeSuccess = false;
            var dmg = _rng.Next(1, 4);
            var flavor = _currentChallenge?.StatName switch
            {
                "Agility"  => $"You slip and crash hard into the rocks — {dmg} damage.",
                "Strength" => $"The obstacle overwhelms you and you are battered — {dmg} damage.",
                "Smarts"   => $"Confusion overwhelms you and you stumble badly — {dmg} damage.",
                _          => $"The challenge strikes back — {dmg} damage."
            };
            var (avoided, mitigMsg) = TryMitigationRoll("Toughness", dmg,
                $"Rolled {roll}+{statVal}={total} vs DC {dc}. FAILED! {flavor}");
            _challengeResultMsg = avoided
                ? $"Rolled {roll}+{statVal}={total} vs DC {dc}. FAILED! {mitigMsg}"
                : mitigMsg;
        }
        _challengeResolved = true;
    }

    private void AttemptRiddle()
    {
        if (_currentChallenge == null) return;
        if (FuzzyMatchRiddle(_riddleAnswer, _currentChallenge.RiddleAnswer!))
        {
            _challengeSuccess = true;
            _challengeResultMsg = "\"Correct!\" The guardian's eyes glow and the path opens.";
        }
        else
        {
            _challengeSuccess = false;
            _challengeResultMsg = "\"Wrong answer, mortal.\" The way remains closed.";
        }
        _challengeResolved = true;
    }

    private static bool FuzzyMatchRiddle(string input, string answer)
    {
        static string Normalize(string s)
        {
            s = s.Trim().ToLower();
            foreach (var article in new[] { "an ", "a ", "the " })
                if (s.StartsWith(article)) s = s[article.Length..];
            return new string(s.Where(char.IsLetterOrDigit).ToArray());
        }
        var normInput  = Normalize(input);
        var normAnswer = Normalize(answer);
        return normInput == normAnswer || normInput.Contains(normAnswer);
    }

    private async Task OnRiddleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AttemptRiddle();
    }

    private void AttemptRiddleStatRoll()
    {
        if (_currentChallenge == null || _character == null) return;
        var statVal = GetCharStat(_character, "Smarts");
        var roll = _rng.Next(1, 21);
        var total = roll + statVal;
        var dc = _currentChallenge.Difficulty + 10;

        if (total >= dc)
        {
            _challengeSuccess = true;
            _challengeResultMsg = $"Rolled {roll}+{statVal}={total} vs DC {dc}. Your wit prevails!";
        }
        else
        {
            _challengeSuccess = false;
            var dmg = _rng.Next(1, 4);
            var (avoided, mitigMsg) = TryMitigationRoll("Magic", dmg,
                $"Rolled {roll}+{statVal}={total} vs DC {dc}. The guardian's eyes blaze and fire bolts of magic — {dmg} damage.");
            _challengeResultMsg = avoided
                ? $"Rolled {roll}+{statVal}={total} vs DC {dc}. The guardian fires, but your Magic wards the bolt! {mitigMsg}"
                : mitigMsg;
        }
        _challengeResolved = true;
    }

    private void AttemptItemChallenge()
    {
        if (_currentChallenge == null) return;
        var needed = _currentChallenge.RequiredItemName!;
        var item = _inventory.FirstOrDefault(i => i.Name.Equals(needed, StringComparison.OrdinalIgnoreCase));
        if (item != null)
        {
            _inventory.Remove(item);
            _challengeSuccess = true;
            _challengeResultMsg = $"You hand over the {needed}. \"You may pass.\"";
        }
        else
        {
            _challengeSuccess = false;
            var dmg = _rng.Next(1, 3);
            var (avoided, mitigMsg) = TryMitigationRoll("Magic", dmg,
                $"You don't have a {needed}. The hermit snarls and curses you with a hex — {dmg} damage.");
            _challengeResultMsg = avoided
                ? $"You don't have a {needed}. The hermit attempts a hex, but your Magic repels it! {mitigMsg}"
                : mitigMsg;
        }
        _challengeResolved = true;
    }

    private void StartCombatChallenge()
    {
        if (_currentChallenge?.EnemyType == null) return;
        _currentEnemy = CreateEnemy(_currentChallenge.EnemyType);
        _combatLog = [$"A {_currentEnemy.Name} appears!"];
        _combatOver = false;
        _combatWon = false;
        _combatResultMsg = "";
        _activeChallenge = false;
        _activeCombat = true;
    }

    private void RetreatFromChallenge()
    {
        // Mark tile as retreated (only for entry challenges)
        if (_pendingMoveTo.HasValue)
        {
            var tile = GetDisplayTile(_pendingMoveTo.Value.Item1, _pendingMoveTo.Value.Item2);
            if (tile != null) tile.RetreatedFrom = true;
        }
        _isExitChallenge = false;
        _currentChallenge = null;
        _pendingMoveTo = null;
        _activeChallenge = false;
        PushStatus("You retreat from the challenge.");
    }

    private void EndChallenge()
    {
        if (_isExitChallenge)
        {
            // Exit challenge: player is already on the tile, success unlocks movement
            if (_challengeSuccess)
            {
                var tile = GetDisplayTile(_playerX, _playerY);
                if (tile != null) tile.ExitChallengeCleared = true;
                _activeExitChallenge = false;
                PushStatus("You break free! The way is clear — you may move again.");
            }
            else
            {
                PushStatus("You are still trapped. Try again!");
                // _activeExitChallenge remains true — player cannot leave
                // Reset challenge state so the player can retry immediately
                _challengeResolved = false;
                _challengeSuccess = false;
                _challengeResultMsg = "";
                _riddleAnswer = "";
                return; // keep _activeChallenge and _isExitChallenge active
            }
            _isExitChallenge = false;
        }
        else if (_challengeSuccess && _pendingMoveTo.HasValue)
        {
            var (tx, ty) = _pendingMoveTo.Value;
            var tile = GetOrGenerateTile(tx, ty);
            tile.ChallengeCleared = true;
            MoveToTile(tx, ty, tile);
            PushStatus("Challenge overcome! You advance.");
        }
        else
        {
            // Failed entry challenge — mark tile as retreated
            if (_pendingMoveTo.HasValue)
            {
                var tile = GetDisplayTile(_pendingMoveTo.Value.Item1, _pendingMoveTo.Value.Item2);
                if (tile != null) tile.RetreatedFrom = true;
            }
            PushStatus("The challenge remains.");
        }
        _currentChallenge = null;
        _pendingMoveTo = null;
        _activeChallenge = false;
    }

    private void TriggerExitChallenge()
    {
        var tile = GetDisplayTile(_playerX, _playerY);
        if (tile?.ExitChallenge == null || tile.ExitChallengeCleared) return;
        _currentChallenge = tile.ExitChallenge;
        _challengeResolved = false;
        _challengeSuccess = false;
        _challengeResultMsg = "";
        _riddleAnswer = "";
        _isExitChallenge = true;
        _activeChallenge = true;
    }

    // ── Combat system ────────────────────────────────────────────────────────
    private void PlayerAttack(string type)
    {
        if (_currentEnemy == null || _character == null || _combatOver) return;

        int attackStat, defenderStat, baseDamage;
        string attackDesc;

        if (type == "ranged" && HasBow())
        {
            attackStat = _character.Agility;
            defenderStat = _currentEnemy.DefenseStat;
            baseDamage = GetBowDamage();
            attackDesc = "fire an arrow";
        }
        else
        {
            attackStat = _character.Strength;
            defenderStat = _currentEnemy.DefenseStat;
            baseDamage = GetMeleeWeaponDamage() + (_character.Strength / 2);
            attackDesc = $"swing your {GetMeleeWeaponName().ToLower()}";
        }

        var atkRoll = _rng.Next(1, 21) + attackStat;
        var defRoll = _rng.Next(1, 21) + defenderStat;

        if (atkRoll >= defRoll)
        {
            var dmg = Math.Max(1, baseDamage - _currentEnemy.Armor);
            _currentEnemy.Hp -= dmg;
            _combatLog.Insert(0, $"You {attackDesc}: {dmg} dmg ({atkRoll} vs {defRoll})");

            if (_currentEnemy.Hp <= 0)
            {
                _combatOver = true;
                _combatWon = true;
                _combatResultMsg = $"VICTORY! {_currentEnemy.Name} defeated!";
                if (_currentEnemy.LootName != null && _inventory.Count < 10
                    && !_inventory.Any(i => i.Name == _currentEnemy.LootName))
                {
                    _inventory.Add(new InventoryItem(_currentEnemy.LootName, _currentEnemy.LootIcon ?? "circle-plus",
                        _currentEnemy.LootDamage, _currentEnemy.LootTooltip));
                    _combatLog.Insert(0, $"Loot: {_currentEnemy.LootName}!");
                }
                if (_rng.Next(3) == 0 && _inventory.Count < 10)
                {
                    _inventory.Add(new InventoryItem("Gem", "gem", 0, "Gem — Precious stone, needed for tolls"));
                    _combatLog.Insert(0, "Loot: Gem!");
                }
                return;
            }
        }
        else
        {
            _combatLog.Insert(0, $"You {attackDesc} but miss ({atkRoll} vs {defRoll})");
        }

        EnemyAttack();
    }

    private void UseHealingPotion()
    {
        if (_combatOver) return;
        var potion = _inventory.FirstOrDefault(i => i.Name == "Healing Potion");
        if (potion == null) return;

        _inventory.Remove(potion);
        var healed = Math.Min(5, _playerMaxHp - _playerHp);
        _playerHp += healed;
        _combatLog.Insert(0, $"You drink a Healing Potion and recover {healed} HP.");

        EnemyAttack();
    }

    private void EnemyAttack()
    {
        if (_currentEnemy == null || _character == null) return;

        var enemyRoll = _rng.Next(1, 21) + _currentEnemy.AttackStat;
        var playerDef = _rng.Next(1, 21) + _character.Agility;

        if (enemyRoll >= playerDef)
        {
            var dmg = Math.Max(1, _currentEnemy.Damage - (_character.Toughness / 2));
            _playerHp -= dmg;
            _combatLog.Insert(0, $"{_currentEnemy.Name} hits: {dmg} dmg");

            if (_playerHp <= 0)
            {
                _playerHp = 0;
                _combatOver = true;
                _combatWon = false;
                _playerDead = true;
                _combatResultMsg = "DEFEATED! You fall in battle...";
            }
        }
        else
        {
            _combatLog.Insert(0, $"{_currentEnemy.Name} misses!");
        }
    }

    private void AttemptFlee()
    {
        if (_character == null || _combatOver) return;

        var fleeRoll = _rng.Next(1, 21) + _character.Speed;
        var enemyRoll = _rng.Next(1, 21) + (_currentEnemy?.AttackStat ?? 3);

        if (fleeRoll >= enemyRoll)
        {
            _combatOver = true;
            _combatWon = false;
            _combatResultMsg = "You flee successfully!";
            _combatLog.Insert(0, "You escape!");
        }
        else
        {
            _combatLog.Insert(0, $"Failed to flee! ({fleeRoll} vs {enemyRoll})");
            if (_inventory.Count > 0)
            {
                var idx = _rng.Next(_inventory.Count);
                var lost = _inventory[idx];
                _inventory.RemoveAt(idx);
                _combatLog.Insert(0, $"Dropped {lost.Name}!");
            }
            EnemyAttack();
        }
    }

    private void EndCombat()
    {
        if (_combatWon && _pendingMoveTo.HasValue)
        {
            var (tx, ty) = _pendingMoveTo.Value;
            var tile = GetOrGenerateTile(tx, ty);
            tile.ChallengeCleared = true;
            MoveToTile(tx, ty, tile);
            PushStatus($"Defeated {_currentEnemy?.Name ?? "enemy"}. You advance.");
        }
        else
        {
            // Fled — mark retreated
            if (_pendingMoveTo.HasValue)
            {
                var tile = GetDisplayTile(_pendingMoveTo.Value.Item1, _pendingMoveTo.Value.Item2);
                if (tile != null) tile.RetreatedFrom = true;
            }
            PushStatus("You escaped the battle.");
        }

        _currentEnemy = null;
        _pendingMoveTo = null;
        _activeCombat = false;
        _playerDead = false;
    }

    private async Task EndCombatDeath()
    {
        // Save score (tiles visited)
        if (UserSession.CurrentUser != null)
        {
            await ScoreService.SaveScoreAsync(UserSession.CurrentUser.Id, "Explorer", _tilesVisited);
        }

        // Reset all state and boot to character picker
        _currentEnemy = null;
        _pendingMoveTo = null;
        _activeCombat = false;
        _activeChallenge = false;
        _playerDead = false;
        _character = null;
        _gameState = GameState.CharSelect;
    }

    // ── Damage mitigation roll ───────────────────────────────────────────────
    private (bool avoided, string msg) TryMitigationRoll(string mitigStat, int dmg, string flavorText)
    {
        if (_character == null) { _playerHp = Math.Max(0, _playerHp - dmg); return (false, flavorText); }
        var statVal = GetCharStat(_character, mitigStat);
        var roll = _rng.Next(1, 21);
        var total = roll + statVal;
        const int mitigDC = 12;
        if (total >= mitigDC)
            return (true, $"Your {mitigStat} ({roll}+{statVal}={total} vs DC {mitigDC}) braces the blow — no damage!");
        _playerHp = Math.Max(0, _playerHp - dmg);
        return (false, flavorText);
    }

    // ── Stat helpers ─────────────────────────────────────────────────────────
    private static int GetCharStat(Character c, string stat) => stat switch
    {
        "Speed" => c.Speed, "Strength" => c.Strength, "Smarts" => c.Smarts,
        "Agility" => c.Agility, "Toughness" => c.Toughness, "Magic" => c.Magic,
        "Health" => c.Health, _ => 1
    };

    private void PushStatus(string message)
    {
        _statusHistory.Insert(0, message);
        if (_statusHistory.Count > 50) _statusHistory.RemoveAt(_statusHistory.Count - 1);
    }

    private void ToggleStatus() => _statusExpanded = !_statusExpanded;

    private void UseItemOutOfCombat(InventoryItem item)
    {
        if (_activeCombat || _activeChallenge) return;
        if (item.Name == "Healing Potion")
        {
            var healed = Math.Min(5, _playerMaxHp - _playerHp);
            if (healed <= 0) { PushStatus("You are already at full health."); return; }
            _inventory.Remove(item);
            _playerHp += healed;
            PushStatus($"You drink the Healing Potion and recover {healed} HP. ({_playerHp}/{_playerMaxHp})");
        }
    }

    private void Rest()
    {
        if (_activeCombat || _activeChallenge || _playerHp >= _playerMaxHp) return;
        var healed = Math.Max(1, (_playerMaxHp - _playerHp) / 2);
        _playerHp = Math.Min(_playerMaxHp, _playerHp + healed);
        PushStatus($"You rest and tend your wounds, recovering {healed} HP. ({_playerHp}/{_playerMaxHp})");
    }

