@page "/flappy"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject UserSession UserSession
@inject ScoreService ScoreService
@implements IAsyncDisposable
@implements IDisposable

<PageTitle>Flappy - Game Studio</PageTitle>

<div class="game-page">
    <div class="game-page-header">
        <a href="/" class="back-btn">← HOME</a>
        <h1 class="retro-title">FLAPPY BIRD</h1>
    </div>

    @if (!initialized)
    {
        <div class="retro-loading">LOADING...</div>
    }
    else if (UserSession.CurrentUser == null)
    {
        <div class="retro-notice">
            <p>CREATE A PLAYER PROFILE FIRST</p>
            <a href="/" class="retro-btn">GO HOME</a>
        </div>
    }
    else
    {
        <div class="game-area">
            <div class="game-player-info">
                PLAYER: @UserSession.CurrentUser.AvatarEmoji @UserSession.CurrentUser.Name
                @if (bestScore != null)
                {
                    <span class="best-score">| BEST: @bestScore.Score</span>
                }
            </div>

            <div class="canvas-container">
                <canvas id="flappyCanvas" width="400" height="600"></canvas>

                @if (gameState == "gameover")
                {
                    <div class="game-over-panel">
                        <div class="game-over-content">
                            <p class="game-over-title">GAME OVER</p>
                            <p class="final-score">SCORE: @finalScore</p>
                            @if (isNewBest)
                            {
                                <p class="new-best">★ NEW BEST! ★</p>
                            }
                            <button class="retro-btn" @onclick="PlayAgain">PLAY AGAIN</button>
                        </div>
                    </div>
                }
            </div>

            <div class="game-controls-hint">SPACE / CLICK / TAP TO FLAP</div>
        </div>
    }
</div>

@code {
    private DotNetObjectReference<Flappy>? _dotNetRef;
    private string gameState = "playing";
    private int finalScore;
    private bool isNewBest;
    private bool initialized;
    private bool gameStarted;
    private ScoreEntry? bestScore;

    protected override void OnInitialized()
    {
        UserSession.OnChange += HandleUserChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!initialized)
        {
            initialized = true;
            StateHasChanged();
            return;
        }

        if (!gameStarted && UserSession.CurrentUser != null)
        {
            gameStarted = true;
            bestScore = await ScoreService.GetHighScoreAsync(UserSession.CurrentUser.Id, "Flappy");
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initFlappy", _dotNetRef);
        }
    }

    private void HandleUserChanged() => _ = InvokeAsync(StateHasChanged);

    [JSInvokable]
    public async Task OnGameOver(int score)
    {
        finalScore = score;
        gameState = "gameover";

        if (UserSession.CurrentUser != null)
        {
            var prevBest = bestScore?.Score ?? -1;
            await ScoreService.SaveScoreAsync(UserSession.CurrentUser.Id, "Flappy", score);
            bestScore = await ScoreService.GetHighScoreAsync(UserSession.CurrentUser.Id, "Flappy");
            isNewBest = score > prevBest;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task PlayAgain()
    {
        gameState = "playing";
        isNewBest = false;
        await JS.InvokeVoidAsync("restartFlappy", _dotNetRef);
    }

    public void Dispose()
    {
        UserSession.OnChange -= HandleUserChanged;
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("destroyFlappy"); } catch { }
        _dotNetRef?.Dispose();
    }
}
