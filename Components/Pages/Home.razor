@page "/"
@rendermode InteractiveServer
@inject ScoreService ScoreService
@inject UserSession UserSession
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Game Studio</PageTitle>

<div class="home-page">
    <h1 class="retro-title-large">GAME STUDIO</h1>
    <p class="retro-subtitle">- TOP SCORES BY GAME -</p>

    @if (gameLeaderboards == null)
    {
        <div class="retro-loading">LOADING...</div>
    }
    else
    {
        <div class="games-grid mt-4">
            <h2 class="retro-title">LEADERBOARDS</h2>
            <div class="game-cards">
                @foreach (var game in ScoreService.Games)
                {
                    var scores = gameLeaderboards.GetValueOrDefault(game) ?? [];
                    var gameName = FormatGameName(game);
                    <div class="game-card" role="button" tabindex="0" @onclick="() => OpenGame(game)">
                        <div class="game-card-icon">@GetGameIcon(game)</div>
                        <div class="game-card-name">@gameName.ToUpper()</div>
                        <div class="game-card-desc">@GetGameDescription(game)</div>
                        @if (_resetTarget == game)
                        {
                            <div class="reset-card-prompt">
                                <input class="reset-pw-input reset-pw-inline" type="password" placeholder="PW"
                                       @bind="_resetPassword" @bind:event="oninput"
                                       @onkeydown="@(async e => { if (e.Key == "Enter") await ConfirmReset(); })" />
                                <button class="retro-btn retro-btn-danger retro-btn-sm"
                                        @onclick:stopPropagation="true"
                                        @onclick="ConfirmReset">OK</button>
                                <button class="retro-btn retro-btn-sm"
                                        @onclick:stopPropagation="true"
                                        @onclick="CancelReset">X</button>
                            </div>
                            @if (_resetError != "")
                            {
                                <div class="reset-error">@_resetError</div>
                            }
                        }
                        else
                        {
                            <button class="retro-btn retro-btn-danger retro-btn-sm"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => StartReset(game)">CLEAR</button>
                        }
                        @if (scores.Count == 0)
                        {
                            <div class="retro-empty">NO SCORES YET</div>
                        }
                        else
                        {
                            @for (var i = 0; i < scores.Count; i++)
                            {
                                var entry = scores[i];
                                var isCurrent = UserSession.CurrentUser?.Id == entry.UserId;
                                <div class="mini-score-row @(isCurrent ? "current-player" : "")">
                                    <span class="score-value">#@(i + 1) @entry.Score</span>
                                    <span class="lb-player">
                                        @entry.User.AvatarEmoji @entry.User.Name @(isCurrent ? "(YOU)" : "")
                                    </span>
                                    <span class="score-date">@entry.PlayedAt.ToLocalTime().ToString("MM/dd/yy HH:mm")</span>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private Dictionary<string, List<ScoreEntry>>? gameLeaderboards;

    protected override void OnInitialized()
    {
        UserSession.OnChange += HandleUserChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private void HandleUserChanged() => _ = InvokeAsync(async () =>
    {
        await LoadData();
        StateHasChanged();
    });

    private async Task LoadData()
    {
        gameLeaderboards = await ScoreService.GetTopScoresByGameAsync(3);
    }

    private static string FormatGameName(string game) =>
        game switch
        {
            "UmmFood" => "Umm Food",
            "CowCoral" => "Cow Coral",
            _ => game
        };

    private static string GetGameIcon(string game) =>
        game switch
        {
            "Flappy" => "🐦",
            "Dodge" => "🐱",
            "UmmFood" => "🤿",
            "Explorer" => "🧭",
            "CowCoral" => "🐎",
            "Forward" => "☠",
            _ => "🎮"
        };

    private static string GetGameDescription(string game) =>
        game switch
        {
            "Flappy" => "DODGE THE PIPES",
            "Dodge" => "RUN THE TRAIL",
            "UmmFood" => "SURVIVE THE WHALES",
            "Explorer" => "EXPLORE THE UNKNOWN",
            "CowCoral" => "CORAL THE COWS",
            "Forward" => "VENTURE INTO THE UNKNOWN",
            _ => "PLAY NOW"
        };

    private void OpenGame(string game)
    {
        var route = game switch
        {
            "Flappy" => "/flappy",
            "Dodge" => "/dodge",
            "UmmFood" => "/umm-food",
            "Explorer" => "/explorer",
            "CowCoral" => "/cow-coral",
            "Forward" => "/forward",
            _ => "/"
        };
        Navigation.NavigateTo(route);
    }

    private string? _resetTarget;
    private string _resetPassword = "";
    private string _resetError = "";

    private void StartReset(string game)
    {
        _resetTarget = game;
        _resetPassword = "";
        _resetError = "";
    }

    private void CancelReset()
    {
        _resetTarget = null;
        _resetPassword = "";
        _resetError = "";
    }

    private async Task ConfirmReset()
    {
        if (_resetPassword != "dungeon")
        {
            _resetError = "WRONG PASSWORD";
            _resetPassword = "";
            return;
        }
        if (_resetTarget != null)
        {
            await ScoreService.ResetGameScoresAsync(_resetTarget);
            await LoadData();
        }
        CancelReset();
    }

    public void Dispose()
    {
        UserSession.OnChange -= HandleUserChanged;
    }
}
